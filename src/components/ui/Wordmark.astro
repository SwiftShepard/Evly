---
interface Props {
  size?: "sm" | "md" | "lg";
  class?: string;
}

const { size = "md", class: className = "" } = Astro.props;

const sizeMap = {
  sm: "text-sm",
  md: "text-base",
  lg: "text-xl",
};
---

<span
  class:list={[
    "font-display font-semibold lowercase inline-flex items-baseline",
    "tracking-[-0.03em] leading-none",
    sizeMap[size],
    className,
  ]}
  role="img"
  aria-label="Evly"
>
  <span aria-hidden="true">ev</span><span
    aria-hidden="true"
    class="text-[var(--color-accent)]"
    style="font-feature-settings: 'ss01';"
  >·</span><span aria-hidden="true">ly</span>
</span>
