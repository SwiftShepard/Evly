---
export interface Props {
  brand: string;
  class?: string;
}

const { brand, class: className = "w-5 h-5" } = Astro.props;

// Discover all SVGs placed in src/assets/logos/ at build time.
// Name your file exactly after the brand: "Renault.svg", "Kia.svg", "Citroën.svg", etc.
const logoModules = import.meta.glob<string>("/src/assets/logos/*.svg", {
  query: "?raw",
  import: "default",
  eager: true,
});

function normalize(s: string) {
  return s
    .toLowerCase()
    .normalize("NFD")
    .replace(/[̀-ͯ]/g, ""); // strip diacritics (Citroën → citroen)
}

const target = normalize(brand);
let patchedSvg: string | null = null;

for (const [path, content] of Object.entries(logoModules)) {
  const stem = path.split("/").at(-1)!.slice(0, -4); // filename without .svg
  if (normalize(stem) === target) {
    // Strip any fixed width/height on the <svg> root, inject our class
    patchedSvg = content.replace(/<svg([^>]*)>/i, (_m, attrs: string) => {
      const cleaned = attrs
        .replace(/\s+width="[^"]*"/gi, "")
        .replace(/\s+height="[^"]*"/gi, "")
        .replace(/\s+class="[^"]*"/gi, "");
      return `<svg${cleaned} class="${className}">`;
    });
    // Normalize hardcoded dark fills → currentColor (light/dark mode compat)
    patchedSvg = patchedSvg
      .replace(/\bfill="(?:#(?:000(?:000)?)|black)"/gi, 'fill="currentColor"')
      .replace(/fill\s*:\s*(?:#(?:000|000000)|rgb\(\s*0\s*,\s*0\s*,\s*0\s*\)|black)\s*;?/gi, "fill:currentColor;")
      .replace(/\bcolor\s*:\s*(?:#fff(?:fff)?|rgb\(\s*255\s*,\s*255\s*,\s*255\s*\)|white)\s*;?/gi, "");
    break;
  }
}

const b = normalize(brand);
---

{patchedSvg ? (
  <Fragment set:html={patchedSvg} />
) : b === "renault" ? (
  <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M12 2L4 12l8 10 8-10-8-10zm0 5l3.5 4.5L12 16l-3.5-4.5L12 7z" fill="currentColor" stroke="none" />
  </svg>
) : b === "kia" ? (
  <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <rect x="1" y="6" width="22" height="12" rx="2" stroke="currentColor" fill="none" />
    <path d="M5 10v4m0-2h3m3-2l-2 4m5-4l-1 4h2l-1-4z" />
  </svg>
) : b === "volkswagen" ? (
  <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="10" stroke="currentColor" />
    <path d="M12 12l-3-10m3 10l3-10m-3 10v10m-8-7l4 7m8-7l-4 7m-4-7l-2-5m6 5l2-5" />
  </svg>
) : b === "hyundai" ? (
  <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <ellipse cx="12" cy="12" rx="10" ry="8" stroke="currentColor" />
    <path d="M6 14l5-6v8m7-4l-5-6v8m-5 4h5" />
  </svg>
) : b === "mobilize" ? (
  <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M4 18L12 6l8 12" />
    <path d="M12 18V6" />
  </svg>
) : b === "citroen" ? (
  <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <ellipse cx="12" cy="12" rx="10" ry="10" stroke="currentColor" stroke-width="1.5" />
    <path d="M7 14l5-4 5 4" />
    <path d="M7 9l5-4 5 4" />
  </svg>
) : b === "peugeot" ? (
  <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
  </svg>
) : b === "leapmotor" ? (
  <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <rect x="3" y="3" width="18" height="18" rx="4" />
    <path d="M8 7v10h8" />
  </svg>
) : b === "tesla" ? (
  <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M12 21V5" />
    <path d="M5 5h14" />
    <path d="M8 9s4-2 4-2 4 2 4 2" />
  </svg>
) : b === "byd" ? (
  <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
    <ellipse cx="12" cy="12" rx="11" ry="7" />
    <text x="12" y="15" text-anchor="middle" font-size="8" font-family="sans-serif" font-weight="bold" stroke="none" fill="currentColor">BYD</text>
  </svg>
) : b === "mg" ? (
  <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
    <polygon points="7 2 17 2 22 7 22 17 17 22 7 22 2 17 2 7" />
    <text x="12" y="16" text-anchor="middle" font-size="9" font-family="sans-serif" font-weight="bold" stroke="none" fill="currentColor">MG</text>
  </svg>
) : (
  <svg class={className} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="10" />
    <path d="M12 8v4l3 3" />
  </svg>
)}
