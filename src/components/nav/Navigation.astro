---
import Wordmark from "@/components/ui/Wordmark.astro";
import { url } from "@/lib/url";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";

const links = [
  { href: url("/vehicules"), label: "Véhicules" },
  { href: url("/leasing-social"), label: "Leasing social" },
  { href: url("/pro"), label: "Pro" },
  { href: url("/comparer"), label: "Comparer" },
  { href: url("/favoris"), label: "Favoris" },
  { href: url("/simulateur"), label: "Simulateur" },
  { href: url("/recommandation"), label: "Recommandation" },
  { href: url("/glossaire"), label: "Glossaire" },
  { href: url("/methodologie"), label: "Méthodologie" },
];

function isActive(href: string): boolean {
  const plain = href.replace(base, "") || "/";
  if (plain === "/") return pathname === "/" || pathname === base;
  return pathname === href || pathname.startsWith(href + "/");
}
---

<header
  class="nav-header sticky top-0 z-40 border-b border-[var(--color-border)] bg-[color-mix(in_srgb,var(--color-bg)_85%,transparent)] backdrop-blur-md"
>
  <div class="container-edit flex items-center justify-between h-14 md:h-16">
    <a
      href={url("/")}
      class="flex items-baseline gap-3 group focus-visible:outline-none min-h-[44px] py-2"
      aria-label="Evly, accueil"
    >
      <Wordmark size="md" />
      <span class="hidden sm:inline label-eyebrow ml-1">L'électrique mesuré</span>
    </a>

    <nav aria-label="Navigation principale" class="hidden md:flex items-center gap-1">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              "nav-link px-3 py-2 text-sm tracking-tight transition-colors min-h-[40px] inline-flex items-center",
              isActive(link.href)
                ? "text-[var(--color-text)]"
                : "text-[var(--color-text-muted)] hover:text-[var(--color-text)]",
            ]}
            aria-current={isActive(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <details class="md:hidden relative">
        <summary
          class="list-none cursor-pointer p-2 text-[var(--color-text-muted)] hover:text-[var(--color-text)] focus-visible:outline-none min-h-[44px] min-w-[44px] flex items-center justify-center"
          aria-label="Ouvrir le menu"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            aria-hidden="true"
          >
            <line x1="3" y1="7" x2="21" y2="7"></line>
            <line x1="3" y1="17" x2="21" y2="17"></line>
          </svg>
        </summary>
        <div
          class="mobile-menu absolute right-0 top-full mt-2 w-60 bg-[var(--color-bg-elevated)] border border-[var(--color-border)] py-2 rounded-[var(--radius-tile-sm)]"
        >
          {
            links.map((link) => (
              <a
                href={link.href}
                class:list={[
                  "block px-4 py-3 text-sm tracking-tight transition-colors min-h-[44px]",
                  isActive(link.href)
                    ? "text-[var(--color-accent)]"
                    : "text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-bg-subtle)]",
                ]}
                aria-current={isActive(link.href) ? "page" : undefined}
              >
                {link.label}
              </a>
            ))
          }
        </div>
      </details>
    </div>
  </div>
</header>
