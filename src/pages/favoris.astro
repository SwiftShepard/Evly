---
import BaseLayout from "@/layouts/BaseLayout.astro";
import FavoritesView from "@/components/favorites/FavoritesView";
import { getAllVehicles } from "@/lib/vehicles";

const vehicles = getAllVehicles();

const summaries = vehicles.map((v) => {
  const cheapest = v.trims.reduce((a, b) => (a.price_EUR < b.price_EUR ? a : b));
  return {
    slug: v.slug,
    brand: v.brand,
    model: v.model,
    variant: v.variant,
    segment: v.segment,
    realRangeMixed: v.realRange.mixed_km,
    dcPeak: v.chargingDC.peakPower_kW,
    price: cheapest.price_EUR,
  };
});
---

<BaseLayout
  title="Favoris, Evly"
  description="Vos véhicules électriques favoris enregistrés localement."
>
  <div class="container-edit py-6 md:py-10">
    <div class="mb-8">
      <div class="flex items-center gap-4 mb-6 fade-rise">
        <span class="font-mono text-xs text-[var(--color-text-faint)]">04</span>
        <span class="label-eyebrow">Favoris</span>
      </div>
      <h1 class="display-1 max-w-3xl fade-rise fade-rise-delay-1">
        Vos coups de coeur,
        <span class="text-[var(--color-text-muted)]">au meme endroit.</span>
      </h1>
      <p class="mt-6 text-base md:text-lg text-[var(--color-text-muted)] max-w-2xl leading-relaxed fade-rise fade-rise-delay-2">
        Cliquez l'etoile sur n'importe quelle fiche pour la retrouver ici.
        Tout reste dans votre navigateur, rien n'est envoyé.
      </p>
    </div>

    <FavoritesView client:load vehicles={summaries} />
  </div>
</BaseLayout>
