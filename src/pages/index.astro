---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BentoGrid from "@/components/ui/BentoGrid.astro";
import Tile from "@/components/ui/Tile.astro";
import Tag from "@/components/ui/Tag.astro";
import Wordmark from "@/components/ui/Wordmark.astro";
import VehicleImage from "@/components/ui/VehicleImage.astro";
import BrandLogo from "@/components/ui/BrandLogo.astro";
import { getAllVehicles } from "@/lib/vehicles";
import { formatPrice } from "@/lib/format";
import { url } from "@/lib/url";
import { getLeasingStatus } from "@/lib/leasing";

const vehicles = getAllVehicles();
const totalVehicles = vehicles.length;
const totalTests = vehicles.reduce((sum, v) => sum + v.rangeTests.length, 0);
const totalConfigs = vehicles.reduce((sum, v) => sum + v.configurations.length, 0);

// "À la une", 2 catégories de véhicules pour scroll rows
const cheapestOf = (v: (typeof vehicles)[number]) => Math.min(...v.trims.map((t) => t.price_EUR));

// Tri par date de dernière mise à jour / ajout (lastUpdated) décroissant, puis par marque/modèle
const latestVehicles = [...vehicles]
  .sort((a, b) => {
    const dateComp = b.lastUpdated.localeCompare(a.lastUpdated);
    if (dateComp !== 0) return dateComp;
    return a.brand.localeCompare(b.brand) || a.model.localeCompare(b.model);
  })
  .slice(0, 10);

const description =
  "Evly, l'électrique mesuré. Comparateur indépendant français : tests d'autonomie réelle (Bjørn Nyland, EVKX, presse FR), dossier leasing social, advocacy consommateur. Aucune publicité, aucun lien affilié.";
---

<BaseLayout title="Evly, l'électrique mesuré" description={description}>
  <div class="container-edit py-6 md:py-10">
    <BentoGrid>

      {/* ═════════ HERO ═════════ */}
      <Tile size="full" variant="elevated" class="md:!p-12 lg:!p-16">
        <div class="flex items-center gap-3 md:gap-4 mb-8 md:mb-12 fade-rise">
          <Wordmark size="lg" />
          <span class="label-eyebrow hidden sm:inline">Édition 2026, France</span>
        </div>

        <h1 class="display-1 max-w-4xl fade-rise fade-rise-delay-1">
          L'électrique se choisit sur les chiffres,
          <span class="text-[var(--color-text-muted)]">pas sur les promesses.</span>
        </h1>

        <p class="mt-6 md:mt-8 text-base md:text-lg text-[var(--color-text-muted)] max-w-2xl leading-relaxed fade-rise fade-rise-delay-2">
          Comparateur d'autonomie réelle indépendant. Zéro publicité, zéro affiliation.
        </p>

        <div class="mt-8 md:mt-10 flex flex-wrap items-center gap-3.5 fade-rise fade-rise-delay-3">
          <a href={url("/vehicules")} class="btn-interactive btn-glow inline-flex items-center gap-2 px-6 py-3.5 bg-[var(--color-accent)] text-[var(--color-accent-on)] text-sm font-semibold tracking-tight min-h-[48px] hover:bg-[var(--color-accent-dim)] transition-colors rounded-[var(--radius-tile-sm)]">
            Explorer le showroom <span class="font-mono">→</span>
          </a>
          <a href={url("/simulateur")} class="btn-interactive inline-flex items-center gap-2 px-6 py-3.5 border border-[var(--color-border-strong)] text-[var(--color-text)] text-sm font-medium tracking-tight min-h-[48px] hover:bg-[var(--color-bg-subtle)] transition-colors rounded-[var(--radius-tile-sm)]">
            Simulateur de coût TCO
          </a>
        </div>

        {/* Mini-stats inline sous le hero */}
        <div class="mt-12 md:mt-16 pt-6 border-t border-[var(--color-border)] flex flex-wrap items-baseline gap-x-8 gap-y-3 font-mono text-[11px] uppercase tracking-[0.14em] text-[var(--color-text-faint)] fade-rise fade-rise-delay-3">
          <span><span data-numeric class="text-[var(--color-text)] text-sm">{totalVehicles}</span> véhicules couverts</span>
          <span><span data-numeric class="text-[var(--color-accent)] text-sm">{totalTests}</span> tests agrégés</span>
          <span><span data-numeric class="text-[var(--color-text)] text-sm">{totalConfigs}</span> configurations comparables</span>
        </div>
      </Tile>

      {/* ═════════ CHEMINS D'ENTRÉE ═════════ */}
      <Tile size="full" variant="default" class="!bg-transparent !border-0 !p-0">
        <div class="flex flex-wrap items-baseline justify-between gap-3 mb-2">
          <span class="font-mono text-xs text-[var(--color-text-faint)]">01 · Par où commencer ?</span>
        </div>
        <h2 class="font-display text-3xl md:text-4xl font-semibold tracking-[-0.015em] leading-[1.1] mb-2">
          Trois chemins selon ton besoin.
        </h2>
        <p class="text-sm text-[var(--color-text-muted)] max-w-2xl">
          Évly est conçu pour des recherches précises, pas pour scroller au hasard. Choisis ton entrée.
        </p>
      </Tile>

      <Tile size="full" variant="default" class="!bg-transparent !border-0 !p-0 !overflow-visible">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          
          <!-- Chemin A : Leasing Social -->
          <a href={url("/leasing-social")} class="path-card group relative flex flex-col justify-between p-6 md:p-8 bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-[var(--radius-tile)] overflow-hidden">
            <div class="glow-bg absolute inset-0 bg-gradient-to-br from-transparent to-[var(--glow-accent)] opacity-0 pointer-events-none"></div>
            
            <div class="relative z-10">
              <div class="flex items-center justify-between mb-6">
                <div class="icon-container w-12 h-12 rounded-xl bg-[var(--color-bg-subtle)] text-[var(--color-text-muted)] flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <span class="index-tag text-xs font-mono text-[var(--color-text-faint)]">A · 01</span>
              </div>
              
              <h3 class="card-title font-display text-2xl font-bold tracking-tight text-[var(--color-text)] mb-3">
                Leasing Social
              </h3>
              
              <div class="mb-5 flex flex-wrap gap-1.5">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-semibold font-mono bg-[rgba(58,92,18,0.08)] text-[var(--color-accent)] border border-[rgba(58,92,18,0.15)]">Dès 95€/mois</span>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-semibold font-mono bg-[var(--color-bg-subtle)] text-[var(--color-text-muted)]">Sans apport</span>
              </div>
              
              <ul class="space-y-2 mb-6">
                <li class="flex items-start gap-2 text-xs text-[var(--color-text-muted)]">
                  <svg class="w-3.5 h-3.5 mt-0.5 text-[var(--color-accent)] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Dossier d'éligibilité complet</span>
                </li>
                <li class="flex items-start gap-2 text-xs text-[var(--color-text-muted)]">
                  <svg class="w-3.5 h-3.5 mt-0.5 text-[var(--color-accent)] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Liste des véhicules compatibles ADEME</span>
                </li>
              </ul>
            </div>
            
            <div class="card-footer relative z-10 mt-auto pt-5 border-t border-[var(--color-border)] flex items-center justify-between text-xs font-bold uppercase tracking-wider text-[var(--color-text)]">
              <span>Voir l'éligibilité</span>
              <span class="arrow-wrapper inline-flex items-center justify-center w-8 h-8 rounded-full bg-[var(--color-bg-subtle)] text-[var(--color-text)]">
                <svg class="arrow-icon w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </a>

          <!-- Chemin B : Comparateur -->
          <a href={url("/comparer")} class="path-card group relative flex flex-col justify-between p-6 md:p-8 bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-[var(--radius-tile)] overflow-hidden">
            <div class="glow-bg absolute inset-0 bg-gradient-to-br from-transparent to-[var(--glow-accent)] opacity-0 pointer-events-none"></div>
            
            <div class="relative z-10">
              <div class="flex items-center justify-between mb-6">
                <div class="icon-container w-12 h-12 rounded-xl bg-[var(--color-bg-subtle)] text-[var(--color-text-muted)] flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 002 2h2a2 2 0 002-2z" />
                  </svg>
                </div>
                <span class="index-tag text-xs font-mono text-[var(--color-text-faint)]">B · 02</span>
              </div>
              
              <h3 class="card-title font-display text-2xl font-bold tracking-tight text-[var(--color-text)] mb-3">
                Comparateur
              </h3>
              
              <div class="mb-5 flex flex-wrap gap-1.5">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-semibold font-mono bg-[var(--color-bg-subtle)] text-[var(--color-text-muted)]">2 à 4 modèles</span>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-semibold font-mono bg-[var(--color-bg-subtle)] text-[var(--color-text-muted)]">Fiches ajustables</span>
              </div>
              
              <ul class="space-y-2 mb-6">
                <li class="flex items-start gap-2 text-xs text-[var(--color-text-muted)]">
                  <svg class="w-3.5 h-3.5 mt-0.5 text-[var(--color-accent)] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Comparatif côte-à-côte direct</span>
                </li>
                <li class="flex items-start gap-2 text-xs text-[var(--color-text-muted)]">
                  <svg class="w-3.5 h-3.5 mt-0.5 text-[var(--color-accent)] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Choix batterie, finitions et jantes</span>
                </li>
              </ul>
            </div>
            
            <div class="card-footer relative z-10 mt-auto pt-5 border-t border-[var(--color-border)] flex items-center justify-between text-xs font-bold uppercase tracking-wider text-[var(--color-text)]">
              <span>Lancer le comparateur</span>
              <span class="arrow-wrapper inline-flex items-center justify-center w-8 h-8 rounded-full bg-[var(--color-bg-subtle)] text-[var(--color-text)]">
                <svg class="arrow-icon w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </a>

          <!-- Chemin C : Recommandation -->
          <a href={url("/recommandation")} class="path-card group relative flex flex-col justify-between p-6 md:p-8 bg-[var(--color-surface-elevated)] border border-[var(--color-border)] rounded-[var(--radius-tile)] overflow-hidden">
            <div class="glow-bg absolute inset-0 bg-gradient-to-br from-transparent to-[var(--glow-accent)] opacity-0 pointer-events-none"></div>
            
            <div class="relative z-10">
              <div class="flex items-center justify-between mb-6">
                <div class="icon-container w-12 h-12 rounded-xl bg-[var(--color-bg-subtle)] text-[var(--color-text-muted)] flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                  </svg>
                </div>
                <span class="index-tag text-xs font-mono text-[var(--color-text-faint)]">C · 03</span>
              </div>
              
              <h3 class="card-title font-display text-2xl font-bold tracking-tight text-[var(--color-text)] mb-3">
                Reco Personnalisée
              </h3>
              
              <div class="mb-5 flex flex-wrap gap-1.5">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-semibold font-mono bg-[var(--color-bg-subtle)] text-[var(--color-text-muted)]">Diagnostic rapide</span>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-semibold font-mono bg-[var(--color-bg-subtle)] text-[var(--color-text-muted)]">3-5 suggestions</span>
              </div>
              
              <ul class="space-y-2 mb-6">
                <li class="flex items-start gap-2 text-xs text-[var(--color-text-muted)]">
                  <svg class="w-3.5 h-3.5 mt-0.5 text-[var(--color-accent)] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Diagnostic basé sur votre usage</span>
                </li>
                <li class="flex items-start gap-2 text-xs text-[var(--color-text-muted)]">
                  <svg class="w-3.5 h-3.5 mt-0.5 text-[var(--color-accent)] flex-shrink-0" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>Ciblage précis du VE idéal</span>
                </li>
              </ul>
            </div>
            
            <div class="card-footer relative z-10 mt-auto pt-5 border-t border-[var(--color-border)] flex items-center justify-between text-xs font-bold uppercase tracking-wider text-[var(--color-text)]">
              <span>Trouver mon VE</span>
              <span class="arrow-wrapper inline-flex items-center justify-center w-8 h-8 rounded-full bg-[var(--color-bg-subtle)] text-[var(--color-text)]">
                <svg class="arrow-icon w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </a>

        </div>
      </Tile>

      {/* ═════════ À LA UNE : DERNIERS VÉHICULES AJOUTÉS ═════════ */}
      <Tile size="full" variant="default" class="!bg-transparent !border-0 !p-0 !mt-4">
        <div class="flex flex-wrap items-baseline justify-between gap-3 mb-2">
          <span class="font-mono text-xs text-[var(--color-text-faint)]">02 · À la une</span>
          <a href={url("/vehicules")} class="font-mono text-[11px] uppercase tracking-[0.12em] text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors">Tout le showroom →</a>
        </div>
        <h2 class="font-display text-3xl md:text-4xl font-semibold tracking-[-0.015em] leading-[1.1] mb-2">
          Derniers véhicules ajoutés.
          <span class="block text-[var(--color-accent)] text-lg md:text-xl mt-1.5 font-medium">
            Les nouveautés et mises à jour récentes du catalogue indépendant.
          </span>
        </h2>
      </Tile>

      <Tile size="full" variant="default" class="!bg-transparent !border-0 !p-0 !overflow-visible">
        <div class="featured-scroll-row">
          {latestVehicles.map((v) => {
            const cheapest = cheapestOf(v);
            const isNew = v.releaseYear >= 2026;
            return (
              <a href={url(`/vehicules/${v.slug}`)} class="featured-card" aria-label={`Fiche ${v.brand} ${v.model}`}>
                <div class="flex items-center justify-between gap-2 mb-3">
                  <div class="flex items-center gap-1.5 text-[var(--color-text-muted)]">
                    <BrandLogo brand={v.brand} class="w-3.5 h-3.5" />
                    <span class="label-eyebrow text-[9px]">{v.brand}</span>
                  </div>
                  <Tag tone={isNew ? "accent" : "default"} mono>
                    {isNew ? "Nouveauté" : "Mis à jour"}
                  </Tag>
                </div>
                <div class="flex items-end justify-between gap-2 mb-4">
                  <h3 class="font-display text-lg md:text-xl font-semibold tracking-[-0.015em] leading-[1.05]">
                    {v.model}
                    <span class="block text-[var(--color-text-muted)] text-xs md:text-sm mt-1 font-medium">{v.variant}</span>
                  </h3>
                  <VehicleImage slug={v.slug} alt={`${v.brand} ${v.model}`} class="w-20 h-12 flex-shrink-0" />
                </div>
                <div class="grid grid-cols-2 gap-3 mt-auto pt-3 border-t border-[var(--color-border)]">
                  <div class="flex flex-col gap-0.5">
                    <span class="font-mono text-[9px] uppercase tracking-[0.14em] text-[var(--color-text-faint)]">Auto.</span>
                    <div class="flex items-baseline gap-1">
                      <span data-numeric class="display-stat text-xl text-[var(--color-accent)]">{v.realRange.mixed_km}</span>
                      <span class="font-mono text-[10px] text-[var(--color-text-faint)]">km</span>
                    </div>
                  </div>
                  <div class="flex flex-col gap-0.5">
                    <span class="font-mono text-[9px] uppercase tracking-[0.14em] text-[var(--color-text-faint)]">Dès</span>
                    <span data-numeric class="display-stat text-xl">{formatPrice(cheapest)}</span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </Tile>

      {/* ═════════ POSITION ÉDITORIALE ═════════ */}
      <Tile size="full" variant="elevated" class="!mt-4">
        <div class="flex items-center gap-4 mb-6">
          <span class="font-mono text-xs text-[var(--color-text-faint)]">03 · Position éditoriale</span>
        </div>
        <h2 class="display-2 max-w-3xl mb-6">
          Pourquoi Evly.
        </h2>
        <p class="text-[var(--color-text-muted)] text-base md:text-lg max-w-3xl leading-relaxed mb-10">
          Le marché des VE est saturé de comparateurs alimentés par la publicité constructeur ou les commissions de leasing. Evly se positionne ailleurs : <strong class="text-[var(--color-text)]">données mesurées, sources tracées, zéro rémunération marque</strong>.
        </p>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8 pt-6 border-t border-[var(--color-border)]">
          <div class="flex flex-col gap-2">
            <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-accent)]">01</span>
            <h3 class="font-display text-lg font-semibold tracking-[-0.01em]">Indépendance</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
              Aucun lien affilié, aucune rémunération constructeur, aucune publicité. Le site tourne sur un hébergement gratuit (Cloudflare Pages).
            </p>
          </div>
          <div class="flex flex-col gap-2">
            <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-accent)]">02</span>
            <h3 class="font-display text-lg font-semibold tracking-[-0.01em]">Sources tracées</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
              Chaque chiffre porte un niveau de confiance (mesuré, constructeur, estimé). Tests Bjørn Nyland, EVKX, ArenaEV, presse VE française et catalogues officiels.
            </p>
          </div>
          <div class="flex flex-col gap-2">
            <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-accent)]">03</span>
            <h3 class="font-display text-lg font-semibold tracking-[-0.01em]">Méthodologie ouverte</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
              Protocoles documentés (WLTP vs autonomie réelle, formule TCO, score ADEME). Les limites éditoriales sont assumées noir sur blanc.
            </p>
          </div>
          <div class="flex flex-col gap-2">
            <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-accent)]">04</span>
            <h3 class="font-display text-lg font-semibold tracking-[-0.01em]">Advocacy consommateur</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
              Quand un véhicule remplit objectivement les critères mais qu'un constructeur refuse de s'engager, Evly le dit. Information + pression commerciale.
            </p>
          </div>
        </div>
      </Tile>

      {/* ═════════ MÉTHODOLOGIE ═════════ */}
      <Tile size="2x1" variant="default" href={url("/methodologie")} ariaLabel="Méthodologie complète" class="reveal">
        <div class="flex items-center gap-3 mb-4">
          <span class="label-eyebrow">04 · Comment on mesure</span>
          <span aria-hidden="true" class="arrow-animate ml-auto font-mono text-[var(--color-text-faint)]">→</span>
        </div>
        <h3 class="font-display text-2xl md:text-3xl font-semibold tracking-[-0.015em] leading-[1.1] mb-3">
          Le WLTP n'est pas une référence d'usage.
        </h3>
        <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mt-auto">
          Approche, protocoles (Nyland / WLTP / EPA / presse FR), formule TCO transparente, registre des sources avec niveaux de confiance, limites assumées.
        </p>
      </Tile>

      <Tile size="2x1" variant="accent" href={url("/vehicules")} ariaLabel="Explorer tous les véhicules" class="reveal">
        <div class="flex items-center gap-3 mb-4">
          <span class="label-eyebrow">05 · Tout le catalogue</span>
          <span aria-hidden="true" class="arrow-animate ml-auto font-mono text-[var(--color-text-faint)]">→</span>
        </div>
