        color: var(--color-accent);
      }

      .path-card:hover .index-tag {
        color: var(--color-accent);
      }

      .path-card:hover .card-title {
        color: var(--color-accent);
      }

      .path-card:hover .card-footer {
        color: var(--color-accent);
      }

      .path-card:hover .arrow-wrapper {
        transform: scale(1.15);
        background-color: var(--color-accent);
        color: var(--color-accent-on);
      }

      .path-card:hover .arrow-icon {
        transform: translateX(3px);
      }

      .path-card:hover .glow-bg {
        opacity: 1;
      }
    }

    /* Transition defaults for card inner elements */
    .path-card .icon-container {
      transition: 
        transform 400ms cubic-bezier(0.16, 1, 0.3, 1),
        background-color 400ms cubic-bezier(0.16, 1, 0.3, 1),
        color 400ms cubic-bezier(0.16, 1, 0.3, 1);
    }

    .path-card .index-tag,
    .path-card .card-title,
    .path-card .card-footer {
      transition: color 400ms cubic-bezier(0.16, 1, 0.3, 1);
    }

    .path-card .arrow-wrapper {
      transition: 
        transform 400ms cubic-bezier(0.16, 1, 0.3, 1),
        background-color 400ms cubic-bezier(0.16, 1, 0.3, 1),
        color 400ms cubic-bezier(0.16, 1, 0.3, 1);
    }

    .path-card .arrow-icon {
      transition: transform 400ms cubic-bezier(0.16, 1, 0.3, 1);
    }

    .path-card .glow-bg {
      transition: opacity 600ms cubic-bezier(0.16, 1, 0.3, 1);
    }

    /* Carrousel horizontal des cards "à la une" */
    .featured-scroll-row {
      display: flex;
      gap: 12px;
      overflow-x: auto;
      padding: 8px 4px 16px 4px;
      margin: -8px -4px 0 -4px;
      scrollbar-width: thin;
      -webkit-overflow-scrolling: touch;
      scroll-snap-type: x mandatory;
    }
    .featured-scroll-row::-webkit-scrollbar { height: 6px; }
    .featured-scroll-row::-webkit-scrollbar-track { background: transparent; }
    .featured-scroll-row::-webkit-scrollbar-thumb {
      background: var(--color-border);
      border-radius: 3px;
    }
    .featured-scroll-row::-webkit-scrollbar-thumb:hover { background: var(--color-border-strong); }

    .featured-card {
      flex: 0 0 auto;
      width: 260px;
      min-height: 180px;
      padding: 16px;
      background: var(--color-bg-elevated);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-tile-sm);
      display: flex;
      flex-direction: column;
      cursor: pointer;
      text-decoration: none;
      color: inherit;
      transition: 
        border-color 450ms cubic-bezier(0.16, 1, 0.3, 1),
        transform 450ms cubic-bezier(0.16, 1, 0.3, 1),
        box-shadow 450ms cubic-bezier(0.16, 1, 0.3, 1);
      scroll-snap-align: start;
    }
    
    @media (hover: hover) {
      .featured-card:hover {
        border-color: var(--color-accent);
