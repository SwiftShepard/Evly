---
import BaseLayout from "@/layouts/BaseLayout.astro";
import StrategicMatcher from "@/components/matcher/StrategicMatcher.tsx";
import { getAllVehicles } from "@/lib/vehicles";

const STRICT_UTILITY_SLUGS = new Set([
  "citroen-e-jumper",
  "citroen-e-jumpy",
  "citroen-e-spacetourer",
  "fiat-e-ducato",
  "fiat-e-scudo",
  "ford-e-transit",
  "kia-pv5-cargo",
  "maxus-edeliver-3",
  "maxus-edeliver-5",
  "maxus-edeliver-7",
  "maxus-edeliver-9",
  "opel-movano-e",
  "opel-vivaro-e-life",
  "peugeot-e-boxer",
  "peugeot-e-expert-combi",
  "peugeot-e-partner",
  "peugeot-e-traveller",
  "renault-master-e-tech",
  "renault-trafic-e-tech",
  "toyota-proace-max-electric",
]);

const vehicles = getAllVehicles().filter(
  (v) =>
    !STRICT_UTILITY_SLUGS.has(v.slug) &&
    v.bodyType !== "Fourgon" &&
    v.bodyType !== "Fourgonnette" &&
    v.bodyType !== "Combi utilitaire"
);
---

<BaseLayout
  title="Trouver sa Voiture Électrique Idéale : Matcher Intelligent | Evly"
  description="🎯 Quelle voiture électrique est faite pour vous ? Faites le test en 2 minutes : diagnostic basé sur vos trajets quotidiens réels, votre budget et votre mode de recharge."
>
  <div class="container-edit py-6 md:py-10">
    <div class="fade-rise fade-rise-delay-1">
      <StrategicMatcher client:load vehicles={vehicles} />
    </div>

    <!-- ═════════ SECTION SEO / DÉCOUVERTE ═════════ -->
    <section class="mt-16 pt-16 border-t border-[var(--color-border)]">
      <h2 class="font-display text-2xl md:text-3xl font-semibold tracking-[-0.015em] mb-6">
        Trouver sa voiture électrique idéale en 2 minutes
      </h2>
      <div class="grid md:grid-cols-2 gap-8 text-sm text-[var(--color-text-muted)] leading-relaxed">
        <div class="flex flex-col gap-4">
          <p>
            Vous ne savez pas quelle voiture électrique choisir parmi la multitude de modèles disponibles sur le marché ? Notre <strong>comparateur de voiture électrique intelligent</strong> vous propose un diagnostic personnalisé et complet pour identifier les véhicules les plus adaptés à vos besoins réels.
          </p>
          <p>
            En répondant à 11 questions simples sur votre profil de trajet quotidien, vos habitudes de recharge, la taille de votre foyer et votre budget maximal, notre algorithme évalue objectivement l'ensemble du catalogue.
          </p>
        </div>
        <div class="flex flex-col gap-4">
          <p>
            Le matcher d'Evly calcule en temps réel votre éligibilité aux aides d'État du dispositif <strong>CEE 2026</strong> et au <strong>Leasing Social</strong> pour estimer les vrais prix nets à l'achat ou en loyer mensuel.
          </p>
          <p>
            Nous analysons également l'importance que vous accordez à la qualité du logiciel embarqué (planificateur d'itinéraire) et au volume de coffre nécessaire pour vos loisirs ou vos enfants, afin de vous proposer un top 3 des modèles les plus pertinents.
          </p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

