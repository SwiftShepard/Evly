---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ComingSoon from "@/components/ui/ComingSoon.astro";
---

<BaseLayout
  title="Recommandation — Evly"
  description="Questionnaire guidé pour identifier les véhicules électriques les plus pertinents selon votre profil d'usage. En cours de développement."
>
  <ComingSoon
    number="05"
    eyebrow="Recommandation"
    title="Six questions, trois véhicules."
    description="Un questionnaire court et précis : votre kilométrage, vos contraintes de recharge, votre budget mensuel, votre tolérance à l'autoroute. En sortie, trois véhicules classés par adéquation, avec une note expliquée — pas un score boîte noire."
    features={[
      "Six étapes maximum, une question par écran, navigation au clavier intégrale",
      "Algorithme de scoring pondéré explicite — chaque critère consultable et modifiable",
      "Résultat partageable par lien, sans tracking ni création de compte",
    ]}
  />
</BaseLayout>
