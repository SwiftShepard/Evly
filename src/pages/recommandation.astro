---
import BaseLayout from "@/layouts/BaseLayout.astro";
import StrategicMatcher from "@/components/matcher/StrategicMatcher.tsx";
import { getAllVehicles } from "@/lib/vehicles";

const vehicles = getAllVehicles();
---

<BaseLayout
  title="Recommandation & Matcher Stratégique | Evly"
  description="Trouvez le véhicule électrique idéal pour vos besoins. Entonnoir de sélection personnalisé selon votre budget, vos trajets réels et vos recharges."
>
  <div class="container-edit py-6 md:py-10">
    <div class="fade-rise fade-rise-delay-1">
      <StrategicMatcher client:load vehicles={vehicles} />
    </div>
  </div>
</BaseLayout>

