---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BentoGrid from "@/components/ui/BentoGrid.astro";
import Tile from "@/components/ui/Tile.astro";
import Tag from "@/components/ui/Tag.astro";
import BrandLogo from "@/components/ui/BrandLogo.astro";
import VehicleImage from "@/components/ui/VehicleImage.astro";
import LeasingEligibilitySimulator from "@/components/leasing/LeasingEligibilitySimulator.tsx";
import { getAllVehicles } from "@/lib/vehicles";
import { formatPrice } from "@/lib/format";
import { url } from "@/lib/url";
import {
  getLeasingStatus,
  LEASING_LABELS,
  LEASING_PRICE_CAP_EUR,
  type LeasingStatus,
} from "@/lib/leasing";

const vehicles = getAllVehicles();

// Group vehicles by leasing status
const grouped: Record<LeasingStatus, typeof vehicles> = {
  "official": [],
  "ademe-compatible": [],
  "potential": [],
  "not-eligible": [],
};
for (const v of vehicles) {
  grouped[getLeasingStatus(v)].push(v);
}

// Sort each group by cheapest price
for (const k of Object.keys(grouped) as LeasingStatus[]) {
  grouped[k].sort(
    (a, b) =>
      Math.min(...a.trims.map((t) => t.price_EUR)) -
      Math.min(...b.trims.map((t) => t.price_EUR)),
  );
}

const counts = {
  official: grouped["official"].length,
  ademe: grouped["ademe-compatible"].length,
  potential: grouped["potential"].length,
};
---

<BaseLayout
  title="Leasing social, comprendre, comparer, exiger | Evly"
  description="Le leasing social 2026 expliqué simplement. Règles d'éligibilité, loyers plafonnés et liste détaillée des voitures électriques éligibles au dispositif."
>
  <div class="py-6 md:py-10">
    <div class="container-edit">
      <BentoGrid>
        {/* ───────── HERO ───────── */}
        <Tile size="full" variant="elevated" class="md:!p-12 lg:!p-16">
          {/* H1 punchy, une ligne max */}
          <h1 class="display-1 max-w-4xl fade-rise fade-rise-delay-1">
            À partir de 95 €/mois,
            <span class="text-[var(--color-accent)]">sans apport.</span>
          </h1>

          {/* Sous-titre éditorial, visiblement plus petit */}
          <p class="mt-6 md:mt-8 font-display text-xl md:text-2xl lg:text-3xl font-medium tracking-[-0.01em] leading-[1.2] text-[var(--color-text-muted)] max-w-3xl fade-rise fade-rise-delay-2">
            Qui peut, comment, et pourquoi tant de modèles éligibles sont absents.
          </p>

          {/* Description body, petit */}
          <p class="mt-8 md:mt-10 text-sm md:text-base text-[var(--color-text-muted)] max-w-2xl leading-relaxed fade-rise fade-rise-delay-3">
            Une location longue durée (LLD/LOA) subventionnée par l'État, sans apport et sous conditions de ressources. Evly décortique les règles du jeu, estime l'éligibilité de votre foyer et liste les modèles officiels ainsi que ceux injustement absents du catalogue des constructeurs.
          </p>

          {/* Stats, séparées clairement par border-top */}
          <div class="mt-12 md:mt-16 pt-6 border-t border-[var(--color-border)] grid grid-cols-2 gap-4 md:gap-8 max-w-md fade-rise fade-rise-delay-3">
            <div class="flex flex-col gap-1.5">
              <span data-numeric class="display-stat text-2xl md:text-3xl text-[var(--color-accent)]">{counts.official}</span>
              <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-text-faint)]">Éligibles<br/>officiels</span>
            </div>
            <div class="flex flex-col gap-1.5">
              <span data-numeric class="display-stat text-2xl md:text-3xl text-[var(--color-warning)]">{counts.ademe}</span>
              <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-text-faint)]">Compatibles<br/>ADEME</span>
            </div>
          </div>
        </Tile>

        {/* ───────── COMMENT ÇA MARCHE ───────── */}
        <Tile size="2x2" variant="default">
          <h2 class="font-display text-2xl md:text-3xl font-semibold tracking-[-0.015em] leading-[1.1] mb-4">
            Le principe en bref
          </h2>
          <p class="text-sm text-[var(--color-text-muted)] mb-6">
            Une formule simple pour accéder à l'électrique sans s'endetter :
          </p>
          <ul class="flex flex-col gap-4 text-sm">
            <li class="flex gap-3 items-start">
              <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] mt-2 shrink-0"></span>
              <span><strong class="text-[var(--color-text)]">Zéro apport</strong> : L'État prend en charge 100 % du premier loyer majoré. Vous ne versez rien au départ.</span>
            </li>
            <li class="flex gap-3 items-start">
              <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] mt-2 shrink-0"></span>
              <span><strong class="text-[var(--color-text)]">Mensualités réduites</strong> : De 95 € à 150 €/mois (maximum légal à 200 €/mois) pendant 3 ans minimum.</span>
            </li>
            <li class="flex gap-3 items-start">
              <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] mt-2 shrink-0"></span>
              <span><strong class="text-[var(--color-text)]">12 000 km/an inclus</strong> : Un forfait annuel adapté aux trajets quotidiens (extensible en option).</span>
            </li>
          </ul>
        </Tile>

        {/* ───────── ÉLIGIBILITÉ MÉNAGE ───────── */}
        <Tile size="2x2" variant="default">
          <h2 class="font-display text-2xl md:text-3xl font-semibold tracking-[-0.015em] leading-[1.1] mb-4">
            Êtes-vous éligible ?
          </h2>
          <p class="text-sm text-[var(--color-text-muted)] mb-6">
            Le dispositif cible les conducteurs modestes avec un usage régulier de leur voiture :
          </p>
          <ul class="flex flex-col gap-4 text-sm">
            <li class="flex gap-3 items-start">
              <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] mt-2 shrink-0"></span>
              <span><strong class="text-[var(--color-text)]">Revenus</strong> : RFR par part ≤ 16 300 € (avis fiscal 2025 sur les revenus 2024).</span>
            </li>
            <li class="flex gap-3 items-start">
              <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] mt-2 shrink-0"></span>
              <span><strong class="text-[var(--color-text)]">Trajet</strong> : Domicile-travail ≥ 15 km aller, OU plus de 8 000 km pro par an.</span>
            </li>
            <li class="flex gap-3 items-start">
              <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] mt-2 shrink-0"></span>
              <span><strong class="text-[var(--color-text)]">Professionnels</strong> : Santé, aide à domicile, artisans et livreurs sont éligibles sans critère de distance.</span>
            </li>
            <li class="flex gap-3 items-start">
              <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] mt-2 shrink-0"></span>
              <span><strong class="text-[var(--color-text)]">Profil</strong> : Résidence fiscale en France, majeur, et ne pas avoir déjà bénéficié de l'aide en 2024.</span>
            </li>
          </ul>
        </Tile>

        {/* ───────── SIMULATEUR INTERACTIF ───────── */}
        <Tile size="full" variant="elevated">
          <LeasingEligibilitySimulator client:load />
        </Tile>

        {/* ───────── SCORE ADEME ───────── */}
        <Tile size="full" variant="elevated">
          <div class="grid md:grid-cols-12 gap-6 md:gap-10">
            <div class="md:col-span-7">
              <h2 class="font-display text-2xl md:text-3xl font-semibold tracking-[-0.015em] leading-[1.1] mb-4">
                L'éco-score ADEME
              </h2>
              <p class="text-sm text-[var(--color-text-muted)] mb-5">
                Pour être subventionné, un modèle doit obtenir un score environnemental ≥ 60/100 mesurant l'empreinte carbone de sa fabrication :
              </p>
              <ul class="flex flex-col gap-3 text-sm">
                <li class="flex gap-3 items-start">
                  <span class="font-mono text-[10px] text-[var(--color-text-faint)] mt-1">70%</span>
                  <span><strong class="text-[var(--color-text)]">Production & Batterie</strong> : Faveur nette à l'assemblage européen grâce à un mix électrique décarboné.</span>
                </li>
                <li class="flex gap-3 items-start">
                  <span class="font-mono text-[10px] text-[var(--color-text-faint)] mt-1">30%</span>
                  <span><strong class="text-[var(--color-text)]">Matériaux</strong> : Empreinte de fabrication de l'acier et de l'aluminium du châssis.</span>
                </li>
              </ul>
            </div>
            <div class="md:col-span-5 flex flex-col gap-4 md:border-l md:border-[var(--color-border)] md:pl-8 justify-center">
              <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-text-faint)]">Estimation du score</span>
              <div class="flex flex-col gap-3">
                <div class="flex items-baseline justify-between gap-3">
                  <span class="text-sm">Assemblé en Europe + Batterie EU</span>
                  <span data-numeric class="font-mono text-[var(--color-accent)] text-lg">~ 75 / 100</span>
                </div>
                <div class="flex items-baseline justify-between gap-3">
                  <span class="text-sm">Assemblé en Europe + Batterie importée</span>
                  <span data-numeric class="font-mono text-[var(--color-warning)] text-lg">~ 62 / 100</span>
                </div>
                <div class="flex items-baseline justify-between gap-3">
                  <span class="text-sm">Produit hors-Europe (ex: Chine)</span>
                  <span data-numeric class="font-mono text-[var(--color-text-faint)] text-lg">~ 45 / 100</span>
                </div>
              </div>
            </div>
          </div>
        </Tile>

        {/* ───────── PRIME CEE VE ───────── */}
        <Tile size="full" variant="default">
          <h2 class="font-display text-2xl md:text-3xl font-semibold tracking-[-0.015em] leading-[1.1] mb-3">
            L'alternative : Prime CEE à l'achat
          </h2>
          <p class="text-sm text-[var(--color-text-muted)] max-w-3xl mb-6">
            Si vous achetez comptant ou en LOA classique, vous bénéficiez d'une remise directe sur facture (non cumulable avec le leasing social) selon votre profil :
          </p>

          <div class="grid md:grid-cols-12 gap-6 md:gap-10">
            <div class="md:col-span-7">
              <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-text-faint)]">Barème selon revenus</span>
              <div class="mt-4 divide-y divide-[var(--color-border)]">
                <div class="flex items-baseline justify-between py-2">
                  <span class="text-sm">Foyers standards</span>
                  <span data-numeric class="font-display text-lg font-medium">jusqu'à 3 500 €</span>
                </div>
                <div class="flex items-baseline justify-between py-2">
                  <span class="text-sm">Foyers modestes</span>
                  <span data-numeric class="font-display text-lg font-medium">jusqu'à 4 700 €</span>
                </div>
                <div class="flex items-baseline justify-between py-2">
                  <span class="text-sm font-medium">Foyers très modestes</span>
                  <span data-numeric class="font-display text-lg font-semibold text-[var(--color-accent)]">jusqu'à 5 700 €</span>
                </div>
              </div>
            </div>

            <div class="md:col-span-5 md:border-l md:border-[var(--color-border)] md:pl-8 flex flex-col justify-center">
              <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-text-faint)]">Bonus industrie européenne</span>
              <div class="mt-3 p-3.5 border-l-2 border-[var(--color-accent)] bg-[color-mix(in_srgb,var(--color-accent)_4%,transparent)]">
                <p class="font-mono text-[11px] text-[var(--color-accent)]">+ 1 200 € à 2 000 €</p>
                <p class="font-display text-sm mt-1 text-[var(--color-text)] leading-snug">
                  Ajoutés si le véhicule et sa batterie sont assemblés en Europe.
                </p>
              </div>
            </div>
          </div>
        </Tile>

        {/* ───────── COÛT RÉEL ATTENTION ───────── */}
        <Tile size="full" variant="default">
          <h2 class="font-display text-2xl md:text-3xl font-semibold tracking-[-0.015em] leading-[1.1] mb-3">
            Le coût d'usage réel
          </h2>
          <p class="text-sm text-[var(--color-text-muted)] max-w-3xl mb-6">
            Attention : le loyer affiché n'est pas le coût final. Comptez réellement <strong class="text-[var(--color-text)]">160 € à 250 €/mois</strong> tout compris :
          </p>
          <div class="grid md:grid-cols-2 gap-4 md:gap-6">
            <div class="p-4 border border-[var(--color-border)] rounded-xl">
              <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-text-faint)]">Inclus de base</span>
              <ul class="mt-3 flex flex-col gap-1 text-sm text-[var(--color-text-muted)]">
                <li>· Location & Garantie constructeur</li>
                <li>· Forfait de 12 000 km/an</li>
              </ul>
            </div>
            <div class="p-4 border border-[var(--color-warning-dim)] rounded-xl bg-[color-mix(in_srgb,var(--color-warning)_4%,transparent)]">
              <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-warning)]">À ajouter au budget</span>
              <ul class="mt-3 flex flex-col gap-1 text-sm text-[var(--color-text-muted)]">
                <li>· Assurance tous risques (indispensable)</li>
                <li>· Entretien, pneumatiques & recharge</li>
                <li>· Restitution (remise en état du véhicule)</li>
              </ul>
            </div>
          </div>
        </Tile>

        {/* ───────── CATÉGORIE A, OFFICIELS ───────── */}
        <Tile size="full" variant="accent">
          <div class="flex flex-wrap items-end justify-between gap-4 mb-2">
            <h2 class="font-display text-3xl md:text-4xl font-semibold tracking-[-0.015em] leading-[1.05]">
              Les modèles disponibles
              <span class="block text-[var(--color-text-muted)] text-lg md:text-xl mt-2 font-medium">
                Offres officielles confirmées, sans apport.
              </span>
            </h2>
            <Tag tone="accent" mono>{counts.official} modèles</Tag>
          </div>
          <p class="text-sm text-[var(--color-text-muted)] mt-4 max-w-3xl">
            Modèles conventionnés avec l'État. Tarifs réels observés de 95 € à 150 €/mois selon la marque.
          </p>
          <div class="mt-4 p-3 border border-[var(--color-border)] rounded-xl bg-[var(--color-bg-subtle)]">
            <p class="text-xs text-[var(--color-text-muted)] leading-relaxed">
              <strong>Non répertoriés ici</strong> : Opel Corsa, Mokka, Jeep Avenger et Nissan Leaf.
            </p>
          </div>
        </Tile>

        {grouped["official"].map((v) => {
          const cheapest = v.trims.reduce((a, b) => (a.price_EUR < b.price_EUR ? a : b));
          return (
            <Tile size="2x1" variant="default" href={url(`/vehicules/${v.slug}`)} ariaLabel={`Fiche ${v.brand} ${v.model}`} class="reveal">
              <div class="flex items-center justify-between gap-3 mb-4">
                <div class="flex items-center gap-2 text-[var(--color-text-muted)]">
                  <BrandLogo brand={v.brand} class="w-4 h-4" />
                  <span class="label-eyebrow">{v.brand}</span>
                </div>
                <Tag tone="accent" mono>Éligible officiel</Tag>
              </div>
              <div class="flex items-end gap-3 mb-6">
                <h3 class="font-display text-2xl md:text-3xl font-semibold tracking-[-0.015em] leading-[1.05]">
                  {v.model}
                  <span class="block text-[var(--color-text-muted)] text-base md:text-lg mt-1 font-medium">{v.variant}</span>
                </h3>
                <div class="flex-1 flex justify-center items-end">
                  <VehicleImage slug={v.slug} alt={`${v.brand} ${v.model}`} class="w-28 h-14" />
                </div>
              </div>
              <div class="grid grid-cols-3 gap-4 mt-auto pt-5 border-t border-[var(--color-border)]">
                <div class="flex flex-col gap-1">
                  <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-text-faint)]">Loyer dès</span>
                  <div class="flex items-baseline gap-1">
                    <span data-numeric class="display-stat text-2xl md:text-3xl text-[var(--color-accent)]">{v.leasingSocial_EUR_per_month}</span>
                    <span class="font-mono text-[11px] text-[var(--color-text-faint)]">€/mois*</span>
                  </div>
                </div>
                <div class="flex flex-col gap-1">
                  <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-text-faint)]">Prix neuf</span>
                  <span data-numeric class="display-stat text-2xl md:text-3xl">{formatPrice(cheapest.price_EUR)}</span>
                </div>
                <div class="flex flex-col gap-1">
                  <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-text-faint)]">Origine</span>
                  <span class="text-sm text-[var(--color-text)] mt-2">{v.productionCountry}</span>
                </div>
              </div>
            </Tile>
          );
        })}

        {/* ───────── CATÉGORIE B, COMPATIBLES ADEME ───────── */}
        <Tile size="full" variant="elevated">
          <div class="flex flex-wrap items-end justify-between gap-4 mb-2">
            <h2 class="font-display text-3xl md:text-4xl font-semibold tracking-[-0.015em] leading-[1.05]">
              Les compatibles absents
              <span class="block text-[var(--color-warning)] text-lg md:text-xl mt-2 font-medium">
                Critères ADEME validés, mais non commercialisés dans le cadre du plan.
              </span>
            </h2>
            <Tag tone="warning" mono>{counts.ademe} modèles</Tag>
          </div>
          <p class="text-sm text-[var(--color-text-muted)] mt-4 max-w-3xl">
            Véhicules produits en Europe à moins de 47 000 € que les constructeurs choisissent de ne pas proposer en leasing social.
          </p>
        </Tile>

        {grouped["ademe-compatible"].map((v) => {
          const cheapest = v.trims.reduce((a, b) => (a.price_EUR < b.price_EUR ? a : b));
          return (
            <Tile size="2x1" variant="default" href={url(`/vehicules/${v.slug}`)} ariaLabel={`Fiche ${v.brand} ${v.model}`} class="reveal">
              <div class="flex items-center justify-between gap-3 mb-4">
                <div class="flex items-center gap-2 text-[var(--color-text-muted)]">
                  <BrandLogo brand={v.brand} class="w-4 h-4" />
                  <span class="label-eyebrow">{v.brand}</span>
                </div>
                <Tag tone="warning" mono>Compatible ADEME</Tag>
              </div>
              <div class="flex items-end gap-3 mb-6">
                <h3 class="font-display text-2xl md:text-3xl font-semibold tracking-[-0.015em] leading-[1.05]">
                  {v.model}
                  <span class="block text-[var(--color-text-muted)] text-base md:text-lg mt-1 font-medium">{v.variant}</span>
                </h3>
                <div class="flex-1 flex justify-center items-end">
                  <VehicleImage slug={v.slug} alt={`${v.brand} ${v.model}`} class="w-28 h-14" />
                </div>
              </div>
              <div class="grid grid-cols-3 gap-4 mt-auto pt-5 border-t border-[var(--color-border)]">
                <div class="flex flex-col gap-1">
                  <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-text-faint)]">Dès</span>
                  <span data-numeric class="display-stat text-2xl md:text-3xl">{formatPrice(cheapest.price_EUR)}</span>
                </div>
                <div class="flex flex-col gap-1">
                  <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-text-faint)]">Auto. réelle</span>
                  <div class="flex items-baseline gap-1">
                    <span data-numeric class="display-stat text-2xl md:text-3xl">{v.realRange.mixed_km}</span>
                    <span class="font-mono text-[11px] text-[var(--color-text-faint)]">km</span>
                  </div>
                </div>
                <div class="flex flex-col gap-1">
                  <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-text-faint)]">Origine</span>
                  <span class="text-sm text-[var(--color-text)] mt-2">{v.productionCountry}</span>
                </div>
              </div>
            </Tile>
          );
        })}



        {/* ───────── ADVOCACY CTA ───────── */}
        <Tile size="full" variant="elevated">
          <h2 class="display-2 max-w-3xl">
            Le leasing social ne devrait pas dépendre du bon vouloir des constructeurs.
          </h2>
          <p class="mt-6 text-[var(--color-text-muted)] text-base md:text-lg max-w-3xl leading-relaxed">
            Evly ne reçoit aucune rémunération constructeur et n'a aucun intérêt à pousser tel ou tel modèle. La liste des véhicules <em>compatibles ADEME mais absents</em> est publique pour une raison : tant que le programme repose sur l'engagement volontaire des marques, le citoyen éligible est privé de choix qu'il devrait avoir.
          </p>
          <div class="mt-8 pt-6 border-t border-[var(--color-border)] flex flex-col md:flex-row gap-4">
            <a
              href="https://mon-leasing-electrique.gouv.fr"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center justify-center gap-2 px-5 py-3 border border-[var(--color-text)] text-sm font-mono tracking-tight hover:bg-[var(--color-text)] hover:text-[var(--color-bg)] transition-colors"
            >
              Vérifier mon éligibilité officielle ↗
            </a>
            <a
              href={url("/vehicules")}
              class="inline-flex items-center justify-center gap-2 px-5 py-3 border border-[var(--color-border-strong)] text-sm font-mono tracking-tight text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:border-[var(--color-text)] transition-colors"
            >
              Voir tous les véhicules →
            </a>
          </div>
          <p class="mt-6 text-[12px] text-[var(--color-text-faint)] font-mono">
            Les scores ADEME indicatifs sont estimés par Evly à partir du pays d'assemblage et du contenu batterie publié. Le score officiel ADEME requiert un dossier constructeur déposé auprès des services de l'État.
          </p>
        </Tile>
      </BentoGrid>
    </div>
  </div>
</BaseLayout>
