---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BentoGrid from "@/components/ui/BentoGrid.astro";
import Tile from "@/components/ui/Tile.astro";
import Tag from "@/components/ui/Tag.astro";
import BrandLogo from "@/components/ui/BrandLogo.astro";
import VehicleImage from "@/components/ui/VehicleImage.astro";
import { getAllVehicles } from "@/lib/vehicles";
import { formatPrice } from "@/lib/format";
import { url } from "@/lib/url";
import {
  getLeasingStatus,
  LEASING_LABELS,
  LEASING_PRICE_CAP_EUR,
  type LeasingStatus,
} from "@/lib/leasing";

const vehicles = getAllVehicles();

// Group vehicles by leasing status
const grouped: Record<LeasingStatus, typeof vehicles> = {
  "official": [],
  "ademe-compatible": [],
  "potential": [],
  "not-eligible": [],
};
for (const v of vehicles) {
  grouped[getLeasingStatus(v)].push(v);
}

// Sort each group by cheapest price
for (const k of Object.keys(grouped) as LeasingStatus[]) {
  grouped[k].sort(
    (a, b) =>
      Math.min(...a.trims.map((t) => t.price_EUR)) -
      Math.min(...b.trims.map((t) => t.price_EUR)),
  );
}

const counts = {
  official: grouped["official"].length,
  ademe: grouped["ademe-compatible"].length,
  potential: grouped["potential"].length,
};

// Group vehicles by brand under official
const officialByBrand = grouped["official"].reduce((acc, v) => {
  if (!acc[v.brand]) acc[v.brand] = [];
  acc[v.brand].push(v);
  return acc;
}, {} as Record<string, typeof vehicles>);

const sortedOfficialBrands = Object.keys(officialByBrand).sort();

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Accueil",
        "item": new URL("/", Astro.site).toString()
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Leasing Social 2026",
        "item": new URL("/leasing-social", Astro.site).toString()
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Qu'est-ce que le leasing social (ou leasing électrique de l'État) ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Le leasing social est un dispositif gouvernemental français permettant aux ménages les plus modestes d'accéder à une voiture électrique en location longue durée (LLD) ou location avec option d'achat (LOA) pour un loyer très bas, compris entre 95 € et 150 € par mois, sans apport initial, grâce aux subventions publiques."
        }
      },
      {
        "@type": "Question",
        "name": "Quel est le plafond de Revenu Fiscal de Référence (RFR) pour le leasing social 2026 ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Pour être éligible au leasing social 2026, le Revenu Fiscal de Référence (RFR) par part de votre foyer fiscal doit être inférieur ou égal à 16 300 € (sur l'avis d'imposition 2025 portant sur les revenus de 2024)."
        }
      },
      {
        "@type": "Question",
        "name": "Quelles sont les conditions de distance domicile-travail pour être éligible au leasing social ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Vous devez résider à plus de 15 km de votre lieu de travail (distance aller simple) ou justifier d'un kilométrage annuel professionnel supérieur à 8 000 km avec votre véhicule personnel. Certaines professions d'assistance sont dispensées de cette condition de trajet."
        }
      },
      {
        "@type": "Question",
        "name": "Quelles voitures électriques sont éligibles au leasing social en 2026 ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sont éligibles les véhicules électriques ayant un score environnemental ADEME égal ou supérieur à 60/100 (principalement les véhicules assemblés en Europe avec des batteries bas carbone) et dont le prix d'achat neuf ne dépasse pas 47 000 €. Des exemples incluent la Renault 5 E-Tech, Peugeot e-208, Citroën ë-C3, Opel Corsa Electric, Jeep Avenger, ou la nouvelle Skoda Epiq."
        }
      },
      {
        "@type": "Question",
        "name": "Le premier loyer majoré ou apport est-il à la charge du locataire dans le cadre du leasing social ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Non, aucun apport n'est requis de la part du bénéficiaire. L'État prend en charge 100 % du premier loyer majoré (apport) sous forme d'une aide directe, permettant un accès sans apport personnel."
        }
      },
      {
        "@type": "Question",
        "name": "L'assurance tous risques et l'entretien sont-ils inclus dans le loyer du leasing social ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "En général, le loyer de base comprend uniquement la location du véhicule et la garantie constructeur. L'assurance tous risques (hautement recommandée) ainsi que les coûts d'entretien, de pneumatiques et de recharge électrique restent à ajouter à votre budget mensuel."
        }
      }
    ]
  }
];
---

<BaseLayout
  title="Leasing Social 2026 : La Liste Réelle des Voitures (et les pièges à éviter) | Evly"
  description="Profitez au mieux du Leasing Social 2026 ! Découvrez la liste complète des voitures dès 95 €/mois, estimez votre éligibilité en 2 minutes et trouvez le modèle idéal."
  jsonLd={jsonLd}
>
  <div class="py-6 md:py-10">
    <div class="container-edit">
      <BentoGrid>
        {/* ───────── HERO ───────── */}
        <Tile size="full" variant="elevated">
          <div class="grid lg:grid-cols-12 gap-8 items-center">
            {/* Colonne Gauche : Titre et Slogan court */}
            <div class="lg:col-span-5 flex flex-col justify-center">
              <h1 class="display-2 fade-rise fade-rise-delay-1">
                Leasing Social <span class="text-[var(--color-accent)]">2026</span>
              </h1>
              <p class="mt-2 text-lg md:text-xl font-medium text-[var(--color-text-muted)] leading-tight fade-rise fade-rise-delay-2">
                Dès 95 €/mois : La liste réelle (et les pièges à éviter).
              </p>
              <div class="mt-6 flex items-center gap-2 fade-rise fade-rise-delay-3">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-[var(--color-bg-subtle)] text-[var(--color-accent)] font-mono border border-[var(--color-border)]">
                  {counts.official} modèles
                </span>
                <span class="text-xs text-[var(--color-text-faint)] font-mono">officiels et confirmés</span>
              </div>
            </div>

            {/* Colonne Droite : Infos Capitales (Grille 2x2 compacte) */}
            <div class="lg:col-span-7 grid grid-cols-2 gap-3 fade-rise fade-rise-delay-3">
              <div class="p-4 border border-[var(--color-border)] rounded-xl bg-[var(--color-bg-subtle)] flex flex-col justify-between gap-1">
                <span class="font-mono text-[9px] uppercase tracking-wider text-[var(--color-text-faint)]">Mensualités</span>
                <div>
                  <span class="font-display text-lg md:text-xl font-bold text-[var(--color-text)]">Dès 95 €</span>
                  <span class="font-mono text-[10px] text-[var(--color-text-faint)]">/mois</span>
                </div>
              </div>
              <div class="p-4 border border-[var(--color-border)] rounded-xl bg-[var(--color-bg-subtle)] flex flex-col justify-between gap-1">
                <span class="font-mono text-[9px] uppercase tracking-wider text-[var(--color-text-faint)]">Apport initial</span>
                <div>
                  <span class="font-display text-lg md:text-xl font-bold text-[var(--color-accent)]">0 €</span>
                  <span class="font-mono text-[10px] text-[var(--color-text-faint)]"> (sans apport)</span>
                </div>
              </div>
              <div class="p-4 border border-[var(--color-border)] rounded-xl bg-[var(--color-bg-subtle)] flex flex-col justify-between gap-1">
                <span class="font-mono text-[9px] uppercase tracking-wider text-[var(--color-text-faint)]">Plafond revenus</span>
                <div>
                  <span class="font-mono text-sm md:text-base font-semibold text-[var(--color-text)]">RFR ≤ 16 300 €</span>
                  <span class="font-mono text-[10px] text-[var(--color-text-faint)]">/part</span>
                </div>
              </div>
              <div class="p-4 border border-[var(--color-border)] rounded-xl bg-[var(--color-bg-subtle)] flex flex-col justify-between gap-1">
                <span class="font-mono text-[9px] uppercase tracking-wider text-[var(--color-text-faint)]">Trajet requis</span>
                <div>
                  <span class="font-mono text-xs md:text-sm font-semibold text-[var(--color-text)]">≥ 15 km</span>
                  <span class="font-mono text-[10px] text-[var(--color-text-faint)]">aller ou 8k km/an</span>
                </div>
              </div>
            </div>
          </div>
        </Tile>


        {sortedOfficialBrands.map((brand) => (
          <div class="col-span-full flex flex-col gap-3 mt-4 first:mt-0 reveal">
            {/* Séparateur */}
            <div class="flex items-center gap-4">
              <div class="flex items-center gap-2.5 px-3.5 py-2 bg-[var(--color-bg-subtle)] border border-[var(--color-border)] rounded-xl">
                <BrandLogo brand={brand} class="w-5 h-5" />
                <span class="font-display font-semibold text-base text-[var(--color-text)]">{brand}</span>
              </div>
              <div class="h-px flex-1 bg-[var(--color-border)]"></div>
              <Tag tone="accent" mono>
                {officialByBrand[brand].length} {officialByBrand[brand].length > 1 ? 'modèles' : 'modèle'}
              </Tag>
            </div>

            {/* Grille interne */}
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
              {officialByBrand[brand].map((v) => {
                const cheapest = v.trims.reduce((a, b) => (a.price_EUR < b.price_EUR ? a : b));
                return (
                  <Tile size="2x1" variant="default" href={url(`/vehicules/${v.slug}`)} ariaLabel={`Fiche ${v.brand} ${v.model}`}>
                    <div class="flex items-center justify-between gap-3 mb-4">
                      <div class="flex items-center gap-2 text-[var(--color-text-muted)]">
                        <BrandLogo brand={v.brand} class="w-4 h-4" />
                        <span class="label-eyebrow">{v.brand}</span>
                      </div>
                      <Tag tone="accent" mono>Éligible officiel</Tag>
                    </div>
                    <div class="flex items-end gap-3 mb-6">
                      <h3 class="font-display text-2xl md:text-3xl font-semibold tracking-[-0.015em] leading-[1.05]">
                        {v.model}
                        <span class="block text-[var(--color-text-muted)] text-base md:text-lg mt-1 font-medium">{v.variant}</span>
                      </h3>
                      <div class="flex-1 flex justify-center items-end">
                        <VehicleImage slug={v.slug} alt={`${v.brand} ${v.model}`} class="w-28 h-14" />
                      </div>
                    </div>
                    <div class="grid grid-cols-3 gap-4 mt-auto pt-5 border-t border-[var(--color-border)]">
                      <div class="flex flex-col gap-1">
                        <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-text-faint)]">Loyer dès</span>
                        <div class="flex items-baseline gap-1">
                          <span data-numeric class="display-stat text-2xl md:text-3xl text-[var(--color-accent)]">{v.leasingSocial_EUR_per_month}</span>
                          <span class="font-mono text-[11px] text-[var(--color-text-faint)]">€/mois*</span>
                        </div>
                      </div>
                      <div class="flex flex-col gap-1">
                        <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-text-faint)]">Prix neuf</span>
                        <span data-numeric class="display-stat text-2xl md:text-3xl">{formatPrice(cheapest.price_EUR)}</span>
                      </div>
                      <div class="flex flex-col gap-1">
                        <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-text-faint)]">Origine</span>
                        <span class="text-sm text-[var(--color-text)] mt-2">{v.productionCountry}</span>
                      </div>
                    </div>
                  </Tile>
                );
              })}
            </div>
          </div>
        ))}

        {/* ───────── COMMENT ÇA MARCHE ───────── */}
        <Tile size="2x2" variant="default">
          <h2 class="font-display text-2xl md:text-3xl font-semibold tracking-[-0.015em] leading-[1.1] mb-4">
            Leasing Social : Les secrets du dispositif
          </h2>
          <p class="text-sm text-[var(--color-text-muted)] mb-6">
            Une formule simple pour accéder à l'électrique sans s'endetter :
          </p>
          <ul class="flex flex-col gap-4 text-sm">
            <li class="flex gap-3 items-start">
              <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] mt-2 shrink-0"></span>
              <span><strong class="text-[var(--color-text)]">Zéro apport</strong> : L'État prend en charge 100 % du premier loyer majoré. Vous ne versez rien au départ.</span>
            </li>
            <li class="flex gap-3 items-start">
              <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] mt-2 shrink-0"></span>
              <span><strong class="text-[var(--color-text)]">Mensualités réduites</strong> : De 95 € à 150 €/mois (maximum légal à 200 €/mois) pendant 3 ans minimum.</span>
            </li>
            <li class="flex gap-3 items-start">
              <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] mt-2 shrink-0"></span>
              <span><strong class="text-[var(--color-text)]">12 000 km/an inclus</strong> : Un forfait annuel adapté aux trajets quotidiens (extensible en option).</span>
            </li>
          </ul>
        </Tile>

        {/* ───────── ÉLIGIBILITÉ MÉNAGE ───────── */}
        <Tile size="2x2" variant="default">
          <h2 class="font-display text-2xl md:text-3xl font-semibold tracking-[-0.015em] leading-[1.1] mb-4">
            Êtes-vous éligible ? (Test express)
          </h2>
          <p class="text-sm text-[var(--color-text-muted)] mb-6">
            Le dispositif cible les conducteurs modestes avec un usage régulier de leur voiture :
          </p>
          <ul class="flex flex-col gap-4 text-sm">
            <li class="flex gap-3 items-start">
              <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] mt-2 shrink-0"></span>
              <span><strong class="text-[var(--color-text)]">Revenus</strong> : RFR par part ≤ 16 300 € (avis fiscal 2025 sur les revenus 2024).</span>
            </li>
            <li class="flex gap-3 items-start">
              <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] mt-2 shrink-0"></span>
              <span><strong class="text-[var(--color-text)]">Trajet</strong> : Domicile-travail ≥ 15 km aller, OU plus de 8 000 km pro par an.</span>
            </li>
            <li class="flex gap-3 items-start">
              <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] mt-2 shrink-0"></span>
              <span><strong class="text-[var(--color-text)]">Professionnels</strong> : Santé, aide à domicile, artisans et livreurs sont éligibles sans critère de distance.</span>
            </li>
            <li class="flex gap-3 items-start">
              <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] mt-2 shrink-0"></span>
              <span><strong class="text-[var(--color-text)]">Profil</strong> : Résidence fiscale en France, majeur, et ne pas avoir déjà bénéficié de l'aide en 2024.</span>
            </li>
          </ul>
        </Tile>

        {/* ───────── SCORE ADEME ───────── */}
        <Tile size="full" variant="elevated">
          <div class="grid md:grid-cols-12 gap-6 md:gap-10">
            <div class="md:col-span-7">
              <h2 class="font-display text-2xl md:text-3xl font-semibold tracking-[-0.015em] leading-[1.1] mb-4">
                Eco-score ADEME : Le critère qui change tout
              </h2>
              <p class="text-sm text-[var(--color-text-muted)] mb-5">
                Pour être subventionné, un modèle doit obtenir un score environnemental ≥ 60/100 mesurant l'empreinte carbone de sa fabrication :
              </p>
              <ul class="flex flex-col gap-3 text-sm">
                <li class="flex gap-3 items-start">
                  <span class="font-mono text-[10px] text-[var(--color-text-faint)] mt-1">70%</span>
                  <span><strong class="text-[var(--color-text)]">Production & Batterie</strong> : Faveur nette à l'assemblage européen grâce à un mix électrique décarboné.</span>
                </li>
                <li class="flex gap-3 items-start">
                  <span class="font-mono text-[10px] text-[var(--color-text-faint)] mt-1">30%</span>
                  <span><strong class="text-[var(--color-text)]">Matériaux</strong> : Empreinte de fabrication de l'acier et de l'aluminium du châssis.</span>
                </li>
              </ul>
            </div>
            <div class="md:col-span-5 flex flex-col gap-4 md:border-l md:border-[var(--color-border)] md:pl-8 justify-center">
              <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-text-faint)]">Estimation du score</span>
              <div class="flex flex-col gap-3">
                <div class="flex items-baseline justify-between gap-3">
                  <span class="text-sm">Assemblé en Europe + Batterie EU</span>
                  <span data-numeric class="font-mono text-[var(--color-accent)] text-lg">~ 75 / 100</span>
                </div>
                <div class="flex items-baseline justify-between gap-3">
                  <span class="text-sm">Assemblé en Europe + Batterie importée</span>
                  <span data-numeric class="font-mono text-[var(--color-warning)] text-lg">~ 62 / 100</span>
                </div>
                <div class="flex items-baseline justify-between gap-3">
                  <span class="text-sm">Produit hors-Europe (ex: Chine)</span>
                  <span data-numeric class="font-mono text-[var(--color-text-faint)] text-lg">~ 45 / 100</span>
                </div>
              </div>
            </div>
          </div>
        </Tile>

        {/* ───────── COÛT RÉEL ATTENTION ───────── */}
        <Tile size="full" variant="default">
          <h2 class="font-display text-2xl md:text-3xl font-semibold tracking-[-0.015em] leading-[1.1] mb-3">
            Vrai budget : Combien coûte-t-elle réellement ?
          </h2>
          <p class="text-sm text-[var(--color-text-muted)] max-w-3xl mb-6">
            Attention : le loyer affiché n'est pas le coût final. Comptez réellement <strong class="text-[var(--color-text)]">160 € à 250 €/mois</strong> tout compris :
          </p>
          <div class="grid md:grid-cols-2 gap-4 md:gap-6">
            <div class="p-4 border border-[var(--color-border)] rounded-xl">
              <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-text-faint)]">Inclus de base</span>
              <ul class="mt-3 flex flex-col gap-1 text-sm text-[var(--color-text-muted)]">
                <li>· Location & Garantie constructeur</li>
                <li>· Forfait de 12 000 km/an</li>
              </ul>
            </div>
            <div class="p-4 border border-[var(--color-warning-dim)] rounded-xl bg-[color-mix(in_srgb,var(--color-warning)_4%,transparent)]">
              <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-warning)]">À ajouter au budget</span>
              <ul class="mt-3 flex flex-col gap-1 text-sm text-[var(--color-text-muted)]">
                <li>· Assurance tous risques (indispensable)</li>
                <li>· Entretien, pneumatiques & recharge</li>
                <li>· Restitution (remise en état du véhicule)</li>
              </ul>
            </div>
          </div>
        </Tile>

        {/* ───────── FAQ SEO LONG-TAIL ───────── */}
        <Tile size="full" variant="default" class="reveal">
          <h2 class="font-display text-2xl md:text-3xl font-semibold tracking-[-0.015em] leading-[1.1] mb-6">
            FAQ Leasing Social 2026 : Tout comprendre pour en profiter
          </h2>
          <div class="flex flex-col gap-4 mt-6">
            <details class="group border-b border-[var(--color-border)] pb-4 last:border-0">
              <summary class="flex justify-between items-center font-display text-base md:text-lg font-medium cursor-pointer list-none select-none text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors">
                <span>Qu'est-ce que le leasing social (ou leasing électrique de l'État) ?</span>
                <span class="font-mono text-sm transform group-open:rotate-180 transition-transform select-none shrink-0 ml-4">▼</span>
              </summary>
              <p class="mt-3 text-sm text-[var(--color-text-muted)] leading-relaxed max-w-4xl">
                Le leasing social est un dispositif gouvernemental français permettant aux ménages les plus modestes d'accéder à une voiture électrique en location longue durée (LLD) ou location avec option d'achat (LOA) pour un loyer très bas, compris entre 95 € et 150 € par mois, sans apport initial, grâce aux subventions publiques.
              </p>
            </details>

            <details class="group border-b border-[var(--color-border)] pb-4 last:border-0">
              <summary class="flex justify-between items-center font-display text-base md:text-lg font-medium cursor-pointer list-none select-none text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors">
                <span>Quel est le plafond de Revenu Fiscal de Référence (RFR) pour 2026 ?</span>
                <span class="font-mono text-sm transform group-open:rotate-180 transition-transform select-none shrink-0 ml-4">▼</span>
              </summary>
              <p class="mt-3 text-sm text-[var(--color-text-muted)] leading-relaxed max-w-4xl">
                Pour être éligible au leasing social 2026, le Revenu Fiscal de Référence (RFR) par part de votre foyer fiscal doit être inférieur ou égal à 16 300 € (sur l'avis d'imposition 2025 portant sur les revenus de 2024).
              </p>
            </details>

            <details class="group border-b border-[var(--color-border)] pb-4 last:border-0">
              <summary class="flex justify-between items-center font-display text-base md:text-lg font-medium cursor-pointer list-none select-none text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors">
                <span>Quelles sont les conditions de distance domicile-travail pour être éligible ?</span>
                <span class="font-mono text-sm transform group-open:rotate-180 transition-transform select-none shrink-0 ml-4">▼</span>
              </summary>
              <p class="mt-3 text-sm text-[var(--color-text-muted)] leading-relaxed max-w-4xl">
                Vous devez résider à plus de 15 km de votre lieu de travail (distance aller simple) ou justifier d'un kilométrage annuel professionnel supérieur à 8 000 km avec votre véhicule personnel. Notez que certaines professions d'assistance (santé, aide à domicile, etc.) sont dispensées de cette condition de trajet.
              </p>
            </details>

            <details class="group border-b border-[var(--color-border)] pb-4 last:border-0">
              <summary class="flex justify-between items-center font-display text-base md:text-lg font-medium cursor-pointer list-none select-none text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors">
                <span>Quelles voitures électriques sont éligibles au leasing social en 2026 ?</span>
                <span class="font-mono text-sm transform group-open:rotate-180 transition-transform select-none shrink-0 ml-4">▼</span>
              </summary>
              <p class="mt-3 text-sm text-[var(--color-text-muted)] leading-relaxed max-w-4xl">
