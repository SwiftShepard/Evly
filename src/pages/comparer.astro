---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BentoGrid from "@/components/ui/BentoGrid.astro";
import Tile from "@/components/ui/Tile.astro";
import ComparatorView from "@/components/compare/ComparatorView.tsx";
import { getAllVehicles } from "@/lib/vehicles";

const vehicles = getAllVehicles();

// Serialize vehicles data for the React island
const vehiclesData = vehicles.map((v) => ({
  slug: v.slug,
  brand: v.brand,
  model: v.model,
  variant: v.variant,
  segment: v.segment,
  bodyType: v.bodyType,
  architecture_V: v.architecture_V,
  power_kW: v.power_kW,
  power_hp: v.power_hp,
  torque_Nm: v.torque_Nm,
  drivetrain: v.drivetrain,
  motors: v.motors,
  acceleration_0_100_s: v.acceleration_0_100_s,
  topSpeed_kmh: v.topSpeed_kmh,
  usableCapacity_kWh: v.usableCapacity_kWh,
  grossCapacity_kWh: v.grossCapacity_kWh,
  chemistry: v.chemistry,
  mass_kg: v.mass_kg,
  wltp_max_km: v.wltp_max_km,
  wltp_min_km: v.wltp_min_km,
  realRange: v.realRange,
  consumption_mixed_kWh_per_100km: v.consumption_mixed_kWh_per_100km,
  consumption_highway_kWh_per_100km: v.consumption_highway_kWh_per_100km,
  consumption_winter_kWh_per_100km: v.consumption_winter_kWh_per_100km,
  dragCoefficient_Cx: v.dragCoefficient_Cx,
  chargingDC: v.chargingDC,
  chargingAC: v.chargingAC,
  plugAndCharge: v.plugAndCharge,
  v2l: v.v2l,
  v2g: v.v2g,
  v2l_option_EUR: v.v2l_option_EUR,
  chargingCurve: v.chargingCurve,
  rangeTests: v.rangeTests,
  thousandKmChallenge: v.thousandKmChallenge,
  length_mm: v.length_mm,
  width_mm: v.width_mm,
  height_mm: v.height_mm,
  wheelbase_mm: v.wheelbase_mm,
  trunkCapacity_L: v.trunkCapacity_L,
  trunkCapacityFolded_L: v.trunkCapacityFolded_L,
  frunkCapacity_L: v.frunkCapacity_L,
  trims: v.trims,
  leasingSocialEligible: v.leasingSocialEligible,
  leasingSocial_EUR_per_month: v.leasingSocial_EUR_per_month,
  availableAids: v.availableAids,
  configurations: v.configurations,
  warranty: v.warranty,
  keyFeatures: v.keyFeatures,
  verdict: v.verdict,
  lastUpdated: v.lastUpdated,
  sources: v.sources,
  imageCredit: v.imageCredit,
  productionCountry: v.productionCountry,
  assemblyPlant: v.assemblyPlant,
  releaseYear: v.releaseYear,
  marketAvailability: v.marketAvailability,
}));
---

<BaseLayout
  title="Comparateur Voitures Électriques : Comparez 150+ Modèles | Evly"
  description="⚡ Comparez jusqu'à 4 voitures électriques côte-à-côte sans filtre commercial. Analysez les autonomies réelles mesurées, la vitesse de recharge et les prix nets de 150+ modèles."
>
  <!-- Hero : reste dans le container standard -->
  <div class="container-edit pt-6 md:pt-10 pb-8">
    <h1 class="display-1 max-w-4xl fade-rise fade-rise-delay-1">
      Quatre véhicules,
      <span class="text-[var(--color-accent)]">mille décisions de moins.</span>
    </h1>
    <p class="mt-6 text-base md:text-lg text-[var(--color-text-muted)] max-w-2xl leading-relaxed fade-rise fade-rise-delay-2">
      Configurez chaque carte indépendamment, batterie, finition, jantes, et comparez en un coup d'œil.
      Tous les chiffres proviennent de sources documentées.
    </p>
  </div>

  <!-- Comparateur : zone élargie, brise le container -->
  <div class="comparator-wide pb-12">
    <ComparatorView client:load vehicles={vehiclesData} />
  </div>

  <!-- ═════════ SECTION SEO / DÉCOUVERTE ═════════ -->
  <section class="container-edit mt-8 pb-16 pt-12 border-t border-[var(--color-border)]">
    <h2 class="font-display text-2xl md:text-3xl font-semibold tracking-[-0.015em] mb-6">
      Un comparateur de voiture électrique conçu pour l'acheteur, pas pour le vendeur
    </h2>
    <div class="grid md:grid-cols-2 gap-8 text-sm text-[var(--color-text-muted)] leading-relaxed">
      <div class="flex flex-col gap-4">
        <p>
          Le choix d'un véhicule propre est devenu complexe en raison de la multiplication des technologies de batteries (NMC, LFP, 400V vs 800V) et de la disparité entre l'autonomie WLTP et la réalité. Notre <strong>comparateur de voiture électrique indépendant</strong> a été conçu pour simplifier cette décision en vous permettant de confronter de 2 à 4 modèles simultanément selon leurs caractéristiques techniques réelles.
        </p>
        <p>
          Sélectionnez les modèles de votre choix et ajustez précisément leur configuration. Notre outil vous permet de modifier la finition, la capacité de la batterie, le diamètre des jantes et de simuler l'état de santé de la batterie (SoH) ou l'impact des conditions climatiques sur l'autonomie réelle.
        </p>
      </div>
      <div class="flex flex-col gap-4">
        <p>
          En comparant les voitures côte-à-côte, vous pouvez analyser les critères essentiels : puissance utile en kW, vitesse de recharge DC sur autoroute, présence de la pompe à chaleur, habilité du coffre et éligibilité aux bonus fiscaux ou au Leasing Social 2026.
        </p>
        <p>
          Notre objectif est de vous fournir un <strong>comparatif de voiture électrique</strong> neutre et objectif pour vous éviter les mauvaises surprises après l'achat. Toutes les données proviennent de tests routiers réels documentés et de fiches d'homologation officielles.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .comparator-wide {
    width: min(calc(100% - 4rem), 1800px);
    margin-inline: auto;
  }

  @media (max-width: 767px) {
    .comparator-wide {
      width: 100%;
      padding-inline: 1rem;
    }
  }
</style>
