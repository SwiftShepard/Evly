  <script define:vars={{ vehicleSlug: vehicle.slug, initialConfigId: configurations[0]?.id || "default", compareBaseUrl: url("/comparer/") }}>
    let currentConfigId = initialConfigId;
    let currentSoh = 100;
    let currentTempMultiplier = 1.0;

    function updateCompareLink() {
      const link = document.getElementById("compare-link");
      if (link) {
        link.href = `${compareBaseUrl}?v=${vehicleSlug}:${currentConfigId}:${currentSoh}`;
      }
      const mobileLink = document.getElementById("compare-link-mobile");
      if (mobileLink) {
        mobileLink.href = `${compareBaseUrl}?v=${vehicleSlug}:${currentConfigId}:${currentSoh}`;
      }
    }

    function toggleConfigs(id) {
      document.querySelectorAll(".config-wrapper").forEach((el) => {
        el.style.display = el.getAttribute("data-config-id") === id ? "contents" : "none";
      });
      document.querySelectorAll(".sidebar-config").forEach((el) => {
        el.style.display = el.getAttribute("data-config-id") === id ? "block" : "none";
      });
    }

    function updateRanges() {
      // Update range numbers based on currentSoh and currentTempMultiplier
      document.querySelectorAll(".soh-update-range").forEach((el) => {
        const base = parseFloat(el.getAttribute("data-base-range"));
        if (!isNaN(base)) {
          el.textContent = Math.round(base * (currentSoh / 100) * currentTempMultiplier);
        }
      });
    }

    // Init URL sync
    const urlParams = new URLSearchParams(window.location.search);
    const configParam = urlParams.get("config");
    if (configParam) {
      currentConfigId = configParam;
      toggleConfigs(configParam);
    }
    const sohParam = urlParams.get("soh");
    if (sohParam) {
      const parsedSoh = parseInt(sohParam, 10);
      if (!isNaN(parsedSoh) && parsedSoh >= 70 && parsedSoh <= 100) {
        currentSoh = parsedSoh;
      }
    }
    updateCompareLink();

    // Handle interactive toggle
    window.addEventListener("config-changed", (e) => {
      const id = e.detail.configId;
      currentConfigId = id;
      toggleConfigs(id);
      const url = new URL(window.location.href);
      url.searchParams.set("config", id);
      window.history.replaceState(null, "", url.toString());
      updateCompareLink();
    });

    // Handle SoH slider change
    window.addEventListener("soh-changed", (e) => {
      const soh = e.detail.soh;
      currentSoh = soh;
      updateCompareLink();

      // Sync SoH to URL search parameters
      const urlVal = new URL(window.location.href);
      if (soh === 100) {
        urlVal.searchParams.delete("soh");
      } else {
        urlVal.searchParams.set("soh", soh.toString());
      }
      window.history.replaceState(null, "", urlVal.toString());

      // 1. Update range numbers
      updateRanges();

      // 2. Update battery capacity numbers
      document.querySelectorAll(".soh-update-capacity").forEach((el) => {
        const base = parseFloat(el.getAttribute("data-base-capacity"));
        if (!isNaN(base)) {
          const statEl = el.querySelector(".display-stat");
          if (statEl) {
            const newVal = (base * soh / 100).toFixed(1).replace(".", ",");
            statEl.textContent = newVal.endsWith(",0") ? newVal.slice(0, -2) : newVal;
          }
        }
      });

      // 3. Update inline capacity texts
      document.querySelectorAll(".soh-update-text-capacity").forEach((el) => {
        const base = parseFloat(el.getAttribute("data-base-capacity"));
        if (!isNaN(base)) {
          const newVal = (base * soh / 100).toFixed(1).replace(".", ",");
          el.textContent = newVal.endsWith(",0") ? newVal.slice(0, -2) : newVal;
        }
      });

      // 4. Update inline WLTP texts
      document.querySelectorAll(".soh-update-text-wltp").forEach((el) => {
        const base = parseFloat(el.getAttribute("data-base-wltp"));
        if (!isNaN(base)) {
          el.textContent = Math.round(base * soh / 100);
        }
      });
    });

    // Handle Temperature slider change
    window.addEventListener("temperature-changed", (e) => {
      currentTempMultiplier = e.detail.tempMultiplier;
      updateCompareLink();
      updateRanges();
    });
  </script>

