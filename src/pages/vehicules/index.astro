---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BentoGrid from "@/components/ui/BentoGrid.astro";
import Tile from "@/components/ui/Tile.astro";
import Tag from "@/components/ui/Tag.astro";
import BrandLogo from "@/components/ui/BrandLogo.astro";
import VehicleImage from "@/components/ui/VehicleImage.astro";
import { getAllVehicles } from "@/lib/vehicles";
import { formatPrice } from "@/lib/format";
import { url } from "@/lib/url";
import FavoriteButton from "@/components/ui/FavoriteButton";
import type { Vehicle } from "@/data/schemas";

// Véhicules utilitaires stricts (fourgons et versions cargo uniquement) exclus du showroom particuliers
const STRICT_UTILITY_SLUGS = new Set([
  "citroen-e-jumper",
  "citroen-e-jumpy",
  "citroen-e-spacetourer",
  "fiat-e-ducato",
  "fiat-e-scudo",
  "ford-e-transit",
  "kia-pv5-cargo",
  "maxus-edeliver-3",
  "maxus-edeliver-5",
  "maxus-edeliver-7",
  "maxus-edeliver-9",
  "opel-movano-e",
  "opel-vivaro-e-life",
  "peugeot-e-boxer",
  "peugeot-e-expert-combi",
  "peugeot-e-partner",
  "peugeot-e-traveller",
  "renault-master-e-tech",
  "renault-trafic-e-tech",
  "toyota-proace-max-electric",
]);

// Les 10 véhicules mixtes (ludospaces, navettes VIP) présents dans les deux showrooms
const HYBRID_SLUGS = new Set([
  "citroen-e-berlingo",
  "hyundai-staria",
  "kia-pv5-passenger",
  "mercedes-eqv",
  "opel-combo-e-life",
  "peugeot-e-rifter",
  "renault-grand-kangoo",
  "renault-kangoo",
  "toyota-proace-city",
  "toyota-proace-electric",
]);

const vehicles = getAllVehicles().filter((v) => !STRICT_UTILITY_SLUGS.has(v.slug));

function getCategory(v: Vehicle) {
  const body = v.bodyType.toLowerCase();
  const segment = v.segment.toLowerCase();

  if (
    body.includes("monospace") ||
    body.includes("ludospace") ||
    body.includes("van") ||
    v.variant.toLowerCase().includes("monospace") ||
    HYBRID_SLUGS.has(v.slug)
  ) {
    return "Monospace";
  }
  if (body.includes("quadricycle") || v.segment.includes("quadricycle")) return "Quadricycle";
  if (segment.includes("a") || (segment.includes("b") && (body.includes("suv") || body.includes("crossover"))) || body.includes("urbain")) return "Mini-SUV";
  if (body.includes("suv") || body.includes("crossover")) return "SUV";
  if (segment.includes("b") || body.includes("citadine")) return "Citadine";
  if (segment.includes("c") || body.includes("compacte")) return "Berline compacte";
  if (body.includes("berline") || body.includes("hatchback") || segment.includes("d")) return "Berline";

  return "SUV";
}

function isLeasing(v: Vehicle) {
  return v.leasingSocialEligible;
}

function isFamiliale(v: Vehicle) {
  const s = v.segment.toLowerCase();
  return s.includes("d") || s.includes("e") || v.bodyType.toLowerCase().includes("familial") || v.bodyType.toLowerCase().includes("monospace") || v.trunkCapacity_L > 450;
}

function isDaily(v: Vehicle) {
  const s = v.segment.toLowerCase();
  return s.includes("a") || s.includes("b") || s.includes("c");
}

const categories = ["Mini-SUV", "SUV", "Berline compacte", "Berline", "Citadine", "Monospace", "Quadricycle"];
const brands = [...new Set(vehicles.map((v) => v.brand))].sort((a, b) =>
  a.localeCompare(b, "fr", { sensitivity: "base" }),
);

const BRAND_ORIGINS: { label: string; set: Set<string> }[] = [
  { label: "Français", set: new Set(["Alpine", "Citroën", "Peugeot", "Renault"]) },
  { label: "Allemand", set: new Set(["Audi", "BMW", "Mercedes", "Opel", "Porsche", "Smart", "Volkswagen"]) },
  { label: "Italien", set: new Set(["Alfa Romeo", "Fiat", "Lancia"]) },
  { label: "Coréen", set: new Set(["Hyundai", "Kia"]) },
  { label: "Japonais", set: new Set(["Mazda", "Nissan", "Toyota"]) },
  { label: "Américain", set: new Set(["Cadillac", "Ford", "Jeep", "Tesla"]) },
  { label: "Scandinave", set: new Set(["Polestar", "Volvo"]) },
  { label: "Britannique", set: new Set(["Mini"]) },
  { label: "Chinois", set: new Set(["BYD", "Leapmotor", "Maxus", "MG", "Nio", "Xiaomi", "Xpeng", "Zeekr"]) },
];
const assignedBrands = new Set(BRAND_ORIGINS.flatMap((g) => [...g.set]));
const brandGroups = [
  ...BRAND_ORIGINS.map((g) => ({ label: g.label, items: brands.filter((b) => g.set.has(b)) })),
  { label: "Autres", items: brands.filter((b) => !assignedBrands.has(b)) },
].filter((g) => g.items.length > 0);

const budgetFilters = [
  { label: "< 25 k€", value: "25000" },
  { label: "< 35 k€", value: "35000" },
  { label: "< 50 k€", value: "50000" },
  { label: "< 70 k€", value: "70000" },
  { label: "< 100 k€", value: "100000" },
];
const specificFilters = [
  { label: "Favoris", value: "favorites" },
  { label: "Leasing social", value: "leasing" },
  { label: "Coup de pouce CEE", value: "cee" },
  { label: "Recharge rapide", value: "fast-charge" },
  { label: "Made in Europe", value: "eu" },
  { label: "Familiale", value: "familiale" },
];

const europeanCountries = ["France", "Allemagne", "Slovaquie", "Rép. Tchèque", "Pologne", "Espagne", "Italie", "Belgique", "Suède", "Slovénie", "Hongrie", "Autriche", "Portugal"];
function isEU(v: Vehicle) { return europeanCountries.includes(v.productionCountry); }
function hasCEE(v: Vehicle) { return v.availableAids?.some(a => /coup\s*de\s*pouce|prime\s*cee|cee|surbonus|aide/i.test(a.label)) ?? false; }
---

<BaseLayout
  title="Catalogue Voitures Électriques : Autonomies & Vrais Prix | Evly"
  description="⚡ Trouvez la meilleure voiture électrique ! Filtrez 150+ modèles par budget réel, autonomie mesurée sur autoroute, vitesse de charge et éligibilité aux aides d'État."
>
  <div class="py-6 md:py-10">
    <div class="container-edit">
      <div class="relative w-full flex flex-col xl:flex-row gap-8">
        
        {/* Barre latérale (Filtres) (Desktop) */}
        <aside class="hidden xl:block w-[275px] shrink-0 z-10">
          <div class="sticky top-24 flex flex-col gap-0 fade-rise sidebar-sticky">
            {/* Recherche textuelle (Desktop) */}
            <div class="pb-4 mb-4 border-b border-[var(--color-border)]">
              <label class="relative flex items-center w-full">
                <span class="absolute left-3 text-[var(--color-text-faint)] flex items-center pointer-events-none">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                  </svg>
                </span>
                <input
                  type="text"
                  id="catalog-search"
                  placeholder="Rechercher un modèle..."
                  aria-label="Rechercher un véhicule électrique"
                  class="w-full bg-[var(--color-bg-subtle)] border border-[var(--color-border)] rounded-full py-2 pl-9 pr-3 text-sm text-[var(--color-text)] placeholder-[var(--color-text-faint)] focus:outline-none focus:border-[var(--color-accent)] focus:bg-[var(--color-bg)] transition-all duration-200"
                />
              </label>
            </div>

            <details class="filter-section">
              <summary class="filter-section-toggle">Autonomie <span class="filter-chevron" /></summary>
              <div class="filter-section-body flex flex-col gap-4 mt-2">
                <div class="range-toggle-group self-start">
                  <button type="button" id="range-type-real" class="range-toggle-btn" data-active="true">Réelle</button>
                  <button type="button" id="range-type-wltp" class="range-toggle-btn" data-active="false">WLTP</button>
                </div>
                <div class="flex flex-col gap-1.5 w-full">
                  <div class="flex justify-between items-baseline">
                    <span class="text-[10px] text-[var(--color-text-muted)]">Minimum</span>
                    <span class="font-mono text-xs font-semibold text-[var(--color-accent)]"><span id="range-value-display">0</span> km</span>
                  </div>
                  <input
                    type="range"
                    id="range-slider"
                    min="0"
                    max="700"
                    step="20"
                    value="0"
                    class="w-full cursor-pointer"
                  />
                </div>
              </div>
            </details>

            <details class="filter-section">
              <summary class="filter-section-toggle">Coffre <span class="filter-chevron" /></summary>
              <div class="filter-section-body flex flex-col gap-4 mt-2">
                <div class="flex flex-col gap-1.5 w-full">
                  <div class="flex justify-between items-baseline">
                    <span class="text-[10px] text-[var(--color-text-muted)]">Minimum</span>
                    <span class="font-mono text-xs font-semibold text-[var(--color-accent)]"><span id="trunk-value-display">0</span> L</span>
                  </div>
                  <input
                    type="range"
                    id="trunk-slider"
                    min="0"
                    max="800"
                    step="50"
                    value="0"
                    class="w-full cursor-pointer"
                  />
                </div>
              </div>
            </details>

            <details class="filter-section">
              <summary class="filter-section-toggle">Marques <span class="filter-chevron" /></summary>
              <div class="filter-section-body">
                {brandGroups.map((group) => (
                  <div>
                    <p class="filter-subgroup-label">{group.label}</p>
                    <div class="flex flex-wrap gap-1.5">
                      {group.items.map((b) => (
                        <button class="filter-chip" data-filter="brand" data-value={b} aria-pressed="false">
                          <BrandLogo brand={b} class="h-[15px] w-auto max-w-[40px] flex-shrink-0" />
                          <span>{b}</span>
                        </button>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </details>

            <details class="filter-section">
              <summary class="filter-section-toggle">Carrosserie <span class="filter-chevron" /></summary>
              <div class="filter-section-body">
                <div class="flex flex-wrap gap-1.5">
                  {categories.map((c) => (
                    <button class="filter-chip" data-filter="cat" data-value={c} aria-pressed="false">{c}</button>
                  ))}
                </div>
              </div>
            </details>

            <details class="filter-section">
              <summary class="filter-section-toggle">Budget max <span class="filter-chevron" /></summary>
              <div class="filter-section-body">
                <div class="flex flex-wrap gap-1.5">
                  {budgetFilters.map(({ label, value }) => (
                    <button class="filter-chip" data-filter="budget" data-value={value} aria-pressed="false">{label}</button>
                  ))}
                </div>
              </div>
            </details>

            <details class="filter-section">
              <summary class="filter-section-toggle">Spécifique <span class="filter-chevron" /></summary>
              <div class="filter-section-body">
                <div class="flex flex-wrap gap-1.5">
                  {specificFilters.map(({ label, value }) => (
                    <button class="filter-chip" data-filter="specific" data-value={value} aria-pressed="false">{label}</button>
                  ))}
                </div>
              </div>
            </details>

            <button id="reset-filters" class="reset-btn" style="display:none">Tout effacer</button>

          </div>
        </aside>

        {/* Filtres Mobile / Tablette, rangées défilantes */}
        <div class="xl:hidden w-full mb-6 flex flex-col gap-3 fade-rise">
          {/* Recherche textuelle (Mobile) */}
          <div class="w-full">
            <label class="relative flex items-center w-full">
              <span class="absolute left-3 text-[var(--color-text-faint)] flex items-center pointer-events-none">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
              </span>
              <input
                type="text"
                id="catalog-search-mobile"
                placeholder="Rechercher un modèle..."
                aria-label="Rechercher un véhicule électrique"
                class="w-full bg-[var(--color-bg-subtle)] border border-[var(--color-border)] rounded-full py-2 pl-9 pr-3 text-sm text-[var(--color-text)] placeholder-[var(--color-text-faint)] focus:outline-none focus:border-[var(--color-accent)] focus:bg-[var(--color-bg)] transition-all duration-200"
              />
            </label>
          </div>

          <div class="flex flex-col md:flex-row gap-4 p-4 bg-[var(--color-bg-subtle)] border border-[var(--color-border)] rounded-xl">
            <div class="flex items-center justify-between gap-4">
              <span class="font-mono text-[9px] uppercase tracking-[0.14em] text-[var(--color-text-faint)]">Autonomie</span>
              <div class="range-toggle-group">
                <button type="button" id="range-type-real-mobile" class="range-toggle-btn" data-active="true">Réelle</button>
                <button type="button" id="range-type-wltp-mobile" class="range-toggle-btn" data-active="false">WLTP</button>
              </div>
            </div>
            <div class="flex-1 flex items-center gap-3">
              <input
                type="range"
                id="range-slider-mobile"
                min="0"
                max="700"
                step="20"
                value="0"
                class="flex-1 cursor-pointer"
              />
              <span class="font-mono text-xs font-semibold text-[var(--color-accent)] min-w-[55px] text-right"><span id="range-value-display-mobile">0</span> km</span>
            </div>
          </div>

          <div class="flex flex-col md:flex-row gap-4 p-4 bg-[var(--color-bg-subtle)] border border-[var(--color-border)] rounded-xl">
            <div class="flex items-center justify-between gap-4">
              <span class="font-mono text-[9px] uppercase tracking-[0.14em] text-[var(--color-text-faint)]">Coffre</span>
            </div>
            <div class="flex-1 flex items-center gap-3">
              <input
                type="range"
                id="trunk-slider-mobile"
                min="0"
                max="800"
                step="50"
                value="0"
                class="flex-1 cursor-pointer"
              />
              <span class="font-mono text-xs font-semibold text-[var(--color-accent)] min-w-[55px] text-right"><span id="trunk-value-display-mobile">0</span> L</span>
            </div>
          </div>
          <div class="filter-scroll-row">
            {brandGroups.map((group, i) => (
              <>
                {i > 0 && <span class="filter-row-sep" />}
                {group.items.map((b) => (
                  <button class="filter-chip" data-filter="brand" data-value={b} aria-pressed="false">
                    <BrandLogo brand={b} class="h-3 w-auto max-w-[28px] flex-shrink-0" />
                    <span>{b}</span>
                  </button>
                ))}
              </>
            ))}
          </div>
          <div class="filter-scroll-row">
            {categories.map((c) => (
              <button class="filter-chip" data-filter="cat" data-value={c} aria-pressed="false">{c}</button>
            ))}
            <span class="filter-row-sep" />
            {budgetFilters.map(({ label, value }) => (
              <button class="filter-chip" data-filter="budget" data-value={value} aria-pressed="false">{label}</button>
            ))}
            <span class="filter-row-sep" />
            {specificFilters.map(({ label, value }) => (
              <button class="filter-chip" data-filter="specific" data-value={value} aria-pressed="false">{label}</button>
            ))}
          </div>
          <div class="flex">
            <button id="reset-filters-mobile" class="reset-btn" style="display:none">Tout effacer</button>
          </div>
        </div>

        {/* Contenu principal aligné avec container-edit */}
        <main class="flex-1 min-w-0">
          <BentoGrid>
            <Tile size="full" variant="elevated">
              <h1 class="display-1 max-w-3xl fade-rise fade-rise-delay-2">
                Tous les véhicules
                <span class="text-[var(--color-accent)]">· mis à jour {new Date().getFullYear()}.</span>
              </h1>
              <p class="mt-6 text-[var(--color-text-muted)] text-sm md:text-base max-w-2xl fade-rise fade-rise-delay-3">
                Sélectionnez vos critères de filtrage pour affiner la liste.
              </p>
              <div class="mt-8 pt-6 border-t border-[var(--color-border)] flex flex-wrap xl:flex-nowrap items-center gap-2 fade-rise fade-rise-delay-3">
                <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-text-faint)] mr-2">Trier</span>
                <button class="sort-btn" data-sort="default" data-active="true">Défaut</button>
                <button class="sort-btn" data-sort="price-asc">Prix ↑</button>
                <button class="sort-btn" data-sort="price-desc">Prix ↓</button>
                <button class="sort-btn" data-sort="range-desc">Autonomie réelle</button>
                <button class="sort-btn" data-sort="dc-desc">Recharge DC</button>
                <button class="sort-btn" data-sort="ratio-desc">Rapport km/€ ★</button>
                <span class="flex-1"></span>
                <div
                  id="price-mode-toggle"
                  class="price-toggle-group"
                  title="* Montants maximaux (menage precaire + surbonus batterie UE). Coup de pouce CEE 2026, sous conditions de revenus et d'eligibilite ADEME."
                >
                  <button class="price-toggle-btn" data-mode="gross" data-active="true">Brut</button>
                  <button class="price-toggle-btn" data-mode="aided">Après aides max.*</button>
                </div>
              </div>
            </Tile>

        {vehicles.map((v) => {
          const validTrims = v.trims.filter((t) => t.price_EUR !== null);
          const cheapest = validTrims.length > 0 ? validTrims.reduce((a, b) => (a.price_EUR! < b.price_EUR! ? a : b)) : null;
          const totalAids = Math.min(
            8100,
            v.availableAids.reduce((s, a) => s + a.amount_EUR, 0)
          );
          const priceAided = cheapest !== null ? Math.max(0, cheapest.price_EUR! - totalAids) : null;
          const category = getCategory(v);
          
          const familial = isFamiliale(v) ? "Familiale" : "";
          const daily = isDaily(v) ? "Daily" : "";
          const leasing = isLeasing(v) ? "Leasing social" : "";
          const usageTags = [familial, daily, leasing].filter(Boolean).join(",");

          return (
            <div
              data-slug={v.slug}
              data-category={category}
              data-brand={v.brand}
              data-model={v.model}
              data-variant={v.variant}
              data-usage={usageTags}
              data-price={cheapest ? cheapest.price_EUR : ""}
              data-price-aided={priceAided ?? ""}
              data-range={v.realRange.mixed_km}
              data-wltp={v.wltp_max_km}
              data-dc={v.chargingDC.peakPower_kW}
              data-ratio={cheapest ? Math.round(v.realRange.mixed_km / cheapest.price_EUR! * 10000) : 0}
              data-origin={isEU(v) ? "eu" : "other"}
              data-cee={hasCEE(v) ? "1" : "0"}
              data-trunk={v.trunkCapacity_L}
              class="vehicle-card contents"
            >
              <Tile size="2x1" variant="default" href={url(`/vehicules/${v.slug}`)} ariaLabel={`Fiche ${v.brand} ${v.model} ${v.variant}`} class="reveal">
                <div class="flex items-center justify-between gap-3 mb-4">
                  <div class="flex items-center gap-2 text-[var(--color-text-muted)]">
                    <BrandLogo brand={v.brand} class="w-4 h-4" />
                    <span class="label-eyebrow text-[9px] !text-[var(--color-text-faint)]">{v.brand} · {v.segment.split(", ")[0] ?? v.segment}</span>
                  </div>
                  <div class="flex items-center gap-2 flex-wrap justify-end relative z-10">
                    {isLeasing(v) && <Tag tone="accent" mono>Leasing social</Tag>}
                    <FavoriteButton client:visible slug={v.slug} size={15} />
                  </div>
                </div>
                <div class="flex items-end gap-3 mb-6">
                  <h2 class="font-display text-2xl md:text-3xl font-semibold tracking-[-0.015em] leading-[1.05]">
                    {v.model}
                    <span class="block text-[var(--color-text-muted)] text-xs md:text-sm mt-0.5 font-normal tracking-tight leading-tight">{v.variant}</span>
                  </h2>
                  <div class="flex-1 h-14 relative min-w-[120px]">
                    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-44 h-22 flex items-end justify-center">
                      <VehicleImage
                        slug={v.slug}
                        alt={`${v.brand} ${v.model}`}
                        class="w-full h-full"
                      />
                    </div>
                  </div>
                </div>
                <div class="grid grid-cols-2 gap-4 mt-auto pt-5 border-t border-[var(--color-border)]">
                  <div class="flex flex-col gap-1">
                    <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-text-faint)]">
                      <span class="range-mode-real">Auto. réelle</span>
                      <span class="range-mode-wltp">Auto. WLTP</span>
                    </span>
                    <div class="flex items-baseline gap-1">
                      <span data-numeric class="display-stat text-2xl md:text-3xl text-[var(--color-accent)]">
                        <span class="range-mode-real">{v.realRange.mixed_km}</span>
                        <span class="range-mode-wltp">{v.wltp_max_km}</span>
                      </span>
                      <span class="font-mono text-[11px] text-[var(--color-text-faint)]">km</span>
                    </div>
                  </div>
                  <div class="flex flex-col gap-1 text-right items-end">
                    <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-text-faint)]">
                      <span class="price-mode-gross">Dès</span>
                      <span class="price-mode-aided">Après aides max.*</span>
                    </span>
                    <div class="price-mode-gross flex items-baseline justify-end gap-1">
                      {cheapest !== null ? (
                        <span data-numeric class="display-stat text-2xl md:text-3xl">{formatPrice(cheapest.price_EUR!)}</span>
                      ) : (
                        <span class="display-stat text-base md:text-lg text-[var(--color-text-faint)] italic font-normal tracking-tight">Tarif à venir</span>
                      )}
                    </div>
                    <div class="price-mode-aided flex flex-col items-end gap-0.5">
                      {cheapest !== null && priceAided !== null ? (
                        <>
                          <span data-numeric class="display-stat text-2xl md:text-3xl" style="color:var(--color-accent)">{formatPrice(priceAided)}</span>
                          {totalAids > 0 && <span class="font-mono text-[10px] text-[var(--color-text-faint)]" style="text-decoration:line-through">{formatPrice(cheapest.price_EUR!)}</span>}
                        </>
                      ) : (
                        <span class="display-stat text-base md:text-lg text-[var(--color-text-faint)] italic font-normal tracking-tight">Tarif à venir</span>
                      )}
                    </div>
                  </div>
                </div>
              </Tile>
            </div>
          );
        })}
      </BentoGrid>
    </main>
  </div>

  <!-- ═════════ SECTION SEO / DÉCOUVERTE ═════════ -->
  <section class="mt-16 pt-16 border-t border-[var(--color-border)]">
    <h2 class="font-display text-2xl md:text-3xl font-semibold tracking-[-0.015em] mb-6">
      Comment bien utiliser notre comparatif de voitures électriques ?
    </h2>
    <div class="grid md:grid-cols-3 gap-6 text-xs md:text-sm text-[var(--color-text-muted)] leading-relaxed">
      <div class="flex flex-col gap-3">
        <h3 class="font-display text-base font-semibold text-[var(--color-text)]">1. Filtrer par autonomie réelle</h3>
        <p>
          L'autonomie WLTP annoncée par les constructeurs est souvent optimiste. Notre <strong>comparateur de voiture électrique</strong> met l'accent sur l'<strong>autonomie réelle</strong> mesurée lors de tests routiers (mixte et autoroute à 130 km/h). Ajustez le slider d'autonomie pour éliminer les modèles qui ne correspondent pas à vos exigences de longs trajets.
        </p>
      </div>
      <div class="flex flex-col gap-3">
        <h3 class="font-display text-base font-semibold text-[var(--color-text)]">2. Simuler le vrai prix net</h3>
        <p>
          Grâce à l'intégration dynamique du dispositif <strong>CEE 2026</strong>, notre catalogue calcule automatiquement les aides de l'État en fonction de votre situation. Basculez l'affichage en tarif "Net" pour comparer les voitures électriques selon leur coût réel après application des primes, bonus et aides régionales.
        </p>
      </div>
      <div class="flex flex-col gap-3">
        <h3 class="font-display text-base font-semibold text-[var(--color-text)]">3. Comparer les temps de charge</h3>
        <p>
          La puissance de recharge en pic n'est pas le seul indicateur. Analysez la vitesse de recharge en DC (de 10% à 80% d'énergie récupérée en moins de 30 min) pour évaluer le confort d'utilisation lors des longs trajets de vacances en famille ou professionnels.
        </p>
      </div>
    </div>
  </section>

  <script>
    document.addEventListener('astro:page-load', () => {
      const chips    = document.querySelectorAll('.filter-chip');
      const cards    = document.querySelectorAll('.vehicle-card');
      const sortBtns = document.querySelectorAll('.sort-btn');
      const grid     = document.querySelector('.bento-grid');
      const resetBtns = document.querySelectorAll('#reset-filters, #reset-filters-mobile');
      const originalOrder = Array.from(cards);

      const searchDesktop = document.querySelector('#catalog-search');
      const searchMobile  = document.querySelector('#catalog-search-mobile');

      // Price mode, 'gross' | 'aided'
      let priceMode = 'gross';
      let currentSort = 'default';
      let currentSearch = '';

      // Range filter state
      let rangeType = 'real';
      let minRange = 0;
      let minTrunk = 0;

      const sliderDesktop = document.querySelector('#range-slider');
      const sliderMobile  = document.querySelector('#range-slider-mobile');
      const displayDesktop = document.querySelector('#range-value-display');
      const displayMobile  = document.querySelector('#range-value-display-mobile');
      
      const toggleRealDesktop = document.querySelector('#range-type-real');
      const toggleWltpDesktop = document.querySelector('#range-type-wltp');
      const toggleRealMobile  = document.querySelector('#range-type-real-mobile');
      const toggleWltpMobile  = document.querySelector('#range-type-wltp-mobile');

      const trunkSliderDesktop = document.querySelector('#trunk-slider');
      const trunkSliderMobile  = document.querySelector('#trunk-slider-mobile');
      const trunkDisplayDesktop = document.querySelector('#trunk-value-display');
      const trunkDisplayMobile  = document.querySelector('#trunk-value-display-mobile');

      function updateSliderBackground(slider) {
        if (!slider) return;
        const min = slider.min || 0;
        const max = slider.max || 100;
        const val = slider.value;
        const percentage = ((val - min) / (max - min)) * 100;
        slider.style.background = `linear-gradient(to right, var(--color-accent) 0%, var(--color-accent) ${percentage}%, var(--color-border) ${percentage}%, var(--color-border) 100%)`;
      }

      function updateRangeUI() {
        if (sliderDesktop) sliderDesktop.value = minRange;
        if (sliderMobile) sliderMobile.value = minRange;
        if (displayDesktop) displayDesktop.textContent = minRange;
        if (displayMobile) displayMobile.textContent = minRange;

        updateSliderBackground(sliderDesktop);
        updateSliderBackground(sliderMobile);

        const isReal = rangeType === 'real';
        
        // Update body dataset to update card range displays
        document.body.dataset.rangeMode = rangeType;

        // Update toggles active attribute
        if (toggleRealDesktop && toggleWltpDesktop) {
          toggleRealDesktop.setAttribute('data-active', isReal ? 'true' : 'false');
          toggleWltpDesktop.setAttribute('data-active', !isReal ? 'true' : 'false');
        }

        if (toggleRealMobile && toggleWltpMobile) {
          toggleRealMobile.setAttribute('data-active', isReal ? 'true' : 'false');
          toggleWltpMobile.setAttribute('data-active', !isReal ? 'true' : 'false');
        }
      }

      function handleRangeTypeChange(type) {
        rangeType = type;
        updateRangeUI();
        updateFilters();
        updateResetVisibility();
      }

      if (toggleRealDesktop) toggleRealDesktop.addEventListener('click', () => handleRangeTypeChange('real'));
      if (toggleWltpDesktop) toggleWltpDesktop.addEventListener('click', () => handleRangeTypeChange('wltp'));
      if (toggleRealMobile) toggleRealMobile.addEventListener('click', () => handleRangeTypeChange('real'));
      if (toggleWltpMobile) toggleWltpMobile.addEventListener('click', () => handleRangeTypeChange('wltp'));

      function handleSliderInput(e) {
        minRange = +e.target.value;
        updateRangeUI();
        updateFilters();
        updateResetVisibility();
      }

      if (sliderDesktop) sliderDesktop.addEventListener('input', handleSliderInput);
      if (sliderMobile) sliderMobile.addEventListener('input', handleSliderInput);

      function updateTrunkUI() {
        if (trunkSliderDesktop) trunkSliderDesktop.value = minTrunk;
        if (trunkSliderMobile) trunkSliderMobile.value = minTrunk;
        if (trunkDisplayDesktop) trunkDisplayDesktop.textContent = minTrunk;
        if (trunkDisplayMobile) trunkDisplayMobile.textContent = minTrunk;

        updateSliderBackground(trunkSliderDesktop);
        updateSliderBackground(trunkSliderMobile);
      }

      function handleTrunkSliderInput(e) {
        minTrunk = +e.target.value;
        updateTrunkUI();
        updateFilters();
        updateResetVisibility();
      }

      if (trunkSliderDesktop) trunkSliderDesktop.addEventListener('input', handleTrunkSliderInput);
      if (trunkSliderMobile) trunkSliderMobile.addEventListener('input', handleTrunkSliderInput);

      // Initialize search from URL query parameter
      try {
        const urlParams = new URLSearchParams(window.location.search);
        currentSearch = urlParams.get('q') || '';
        if (searchDesktop) searchDesktop.value = currentSearch;
        if (searchMobile) searchMobile.value = currentSearch;
      } catch (e) {}

      function getCardPrice(card) {
        const pStr = priceMode === 'aided' ? (card.dataset.priceAided || card.dataset.price) : card.dataset.price;
        if (!pStr || pStr === 'null' || pStr === 'undefined' || isNaN(pStr)) return Infinity;
        return +pStr;
      }

      // Shared active state across desktop + mobile chip duplicates
      const active = { brand: new Set(), cat: new Set(), budget: new Set(), specific: new Set() };

      function getSelected(type) { return Array.from(active[type]); }

      function syncChips(filter, value) {
        document.querySelectorAll(`.filter-chip[data-filter="${filter}"][data-value="${value}"]`)
          .forEach(c => c.setAttribute('aria-pressed', active[filter].has(value) ? 'true' : 'false'));
      }

      function updateResetVisibility() {
        const any = Object.values(active).some(s => s.size > 0) || 
                    currentSearch.trim() !== '' || 
                    minRange !== 0 || 
                    minTrunk !== 0 || 
                    rangeType !== 'real';
        resetBtns.forEach(b => b.style.display = any ? '' : 'none');
      }

      function getFavorites() {
        try {
          const raw = localStorage.getItem('evly-favorites');
          return raw ? JSON.parse(raw) : [];
        } catch { return []; }
      }

      const handleFavoritesChange = () => {
        updateFilters();
      };
      window.addEventListener('favorites-changed', handleFavoritesChange);
      document.addEventListener('astro:before-swap', () => {
        window.removeEventListener('favorites-changed', handleFavoritesChange);
      }, { once: true });

      function updateFilters() {
        const selBrands   = getSelected('brand');
        const selCats     = getSelected('cat');
        const selBudgets  = getSelected('budget');
        const selSpecific = getSelected('specific');
        const favSlugs    = selSpecific.includes('favorites') ? new Set(getFavorites()) : null;
        const query       = currentSearch.toLowerCase().trim();

        cards.forEach(card => {
          const brand   = card.dataset.brand;
          const cat     = card.dataset.category;
          const price   = getCardPrice(card);
          const dc      = +card.dataset.dc;
          const origin  = card.dataset.origin;
          const cee     = card.dataset.cee === '1';
          const usages  = (card.dataset.usage || '').split(',').filter(Boolean);
          const slug    = card.dataset.slug;
          const model   = (card.dataset.model || '').toLowerCase();
          const variant = (card.dataset.variant || '').toLowerCase();
          const trunk   = +card.dataset.trunk;

          const range = rangeType === 'wltp' ? +card.dataset.wltp : +card.dataset.range;

          let ok = true;
          if (selBrands.length  && !selBrands.includes(brand)) ok = false;
          if (selCats.length    && !selCats.includes(cat))     ok = false;
          if (selBudgets.length) {
            const maxBudget = Math.max(...selBudgets.map(Number));
            if (price > maxBudget) ok = false;
          }
          if (range < minRange) ok = false;
          if (trunk < minTrunk) ok = false;
          if (selSpecific.length) {
            for (const s of selSpecific) {
              if (s === 'favorites'   && (!favSlugs || !favSlugs.has(slug)))  { ok = false; break; }
              if (s === 'fast-charge' && dc < 100)                     { ok = false; break; }
              if (s === 'eu'          && origin !== 'eu')               { ok = false; break; }
              if (s === 'cee'          && !cee)                         { ok = false; break; }
              if (s === 'leasing'     && !usages.includes('Leasing social')) { ok = false; break; }
              if (s === 'familiale'   && !usages.includes('Familiale'))      { ok = false; break; }
            }
          }
          if (query) {
            if (!model.includes(query) && !brand.toLowerCase().includes(query) && !variant.includes(query)) {
              ok = false;
            }
          }
          card.style.display = ok ? 'contents' : 'none';
        });
      }

      function handleSearchInput(e) {
        currentSearch = e.target.value;
        if (searchDesktop && searchDesktop !== e.target) searchDesktop.value = currentSearch;
        if (searchMobile && searchMobile !== e.target) searchMobile.value = currentSearch;
        updateFilters();
        updateResetVisibility();
      }

      if (searchDesktop) searchDesktop.addEventListener('input', handleSearchInput);
      if (searchMobile) searchMobile.addEventListener('input', handleSearchInput);

      chips.forEach(chip => {
        chip.addEventListener('click', () => {
          const f = chip.dataset.filter;
          const v = chip.dataset.value;
          if (active[f].has(v)) active[f].delete(v);
          else                   active[f].add(v);
          syncChips(f, v);
          updateFilters();
          updateResetVisibility();
        });
      });

      resetBtns.forEach(btn => btn.addEventListener('click', () => {
        Object.values(active).forEach(s => s.clear());
        chips.forEach(c => c.setAttribute('aria-pressed', 'false'));
        currentSearch = '';
        if (searchDesktop) searchDesktop.value = '';
        if (searchMobile) searchMobile.value = '';
        
        // Reset range filters
        rangeType = 'real';
        minRange = 0;
        updateRangeUI();

        // Reset trunk filter
        minTrunk = 0;
        updateTrunkUI();
        
        updateFilters();
        updateResetVisibility();
      }));

      function applySort(sortKey) {
        currentSort = sortKey;
        sortBtns.forEach(btn => delete btn.dataset.active);
        const activeSortBtn = document.querySelector(`.sort-btn[data-sort="${sortKey}"]`);
        if (activeSortBtn) activeSortBtn.setAttribute('data-active', 'true');
        const sorted = sortKey === 'default'
          ? [...originalOrder]
          : [...originalOrder].sort((a, b) => {
              switch (sortKey) {
                case 'price-asc': {
                  const pa = getCardPrice(a);
                  const pb = getCardPrice(b);
                  if (pa === pb) return 0;
                  if (pa === Infinity) return 1;
                  if (pb === Infinity) return -1;
                  return pa - pb;
                }
                case 'price-desc': {
                  const pa = getCardPrice(a);
                  const pb = getCardPrice(b);
                  if (pa === pb) return 0;
                  if (pa === Infinity) return 1;
                  if (pb === Infinity) return -1;
                  return pb - pa;
                }
                case 'range-desc': return +b.dataset.range - +a.dataset.range;
                case 'dc-desc':    return +b.dataset.dc    - +a.dataset.dc;
                case 'ratio-desc': return +b.dataset.ratio - +a.dataset.ratio;
                default:           return 0;
              }
            });
        sorted.forEach(card => grid.appendChild(card));
      }

      sortBtns.forEach(btn => btn.addEventListener('click', () => applySort(btn.dataset.sort)));

      // Price mode toggle
      const priceBtns = document.querySelectorAll('.price-toggle-btn');
      priceBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          priceMode = btn.dataset.mode;
          priceBtns.forEach(b => delete b.dataset.active);
          btn.setAttribute('data-active', 'true');
          document.body.dataset.priceMode = priceMode;
          updateFilters();
          applySort(currentSort);
        });
      });

      // Initialize defaults on load
      document.body.dataset.priceMode = priceMode;
      updateRangeUI();
      updateTrunkUI();

      // Run initial filter on load if URL contains query parameter
      if (currentSearch) {
        updateFilters();
        updateResetVisibility();
      }
    });
  </script>

  <style>
    /* ── Sticky Sidebar ─────────────────────────────────── */
    .sidebar-sticky {
      max-height: calc(100vh - 8rem);
      overflow-y: auto;
      padding-right: 4px;
      scrollbar-width: thin;
    }
    .sidebar-sticky::-webkit-scrollbar {
      width: 4px;
    }
    .sidebar-sticky::-webkit-scrollbar-track {
      background: transparent;
    }
    .sidebar-sticky::-webkit-scrollbar-thumb {
      background: var(--color-border);
      border-radius: 2px;
    }
    .sidebar-sticky::-webkit-scrollbar-thumb:hover {
      background: var(--color-border-strong);
    }

    /* ── Filter chips ───────────────────────────────────── */
    .filter-chip {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 5px 10px;
      border-radius: 6px;
      border: 1px solid var(--color-border);
      background: transparent;
      color: var(--color-text-muted);
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 0.68rem;
      letter-spacing: 0.025em;
      cursor: pointer;
      transition: background 0.12s, border-color 0.12s, color 0.12s, transform 0.08s;
      white-space: nowrap;
      -webkit-tap-highlight-color: transparent;
      user-select: none;
      line-height: 1.2;
    }
    .filter-chip:hover {
      background: var(--color-bg-subtle);
      border-color: var(--color-border-strong);
      color: var(--color-text);
    }
    .filter-chip:active { transform: scale(0.96); }
    .filter-chip[aria-pressed="true"] {
      background: var(--color-accent);
      border-color: var(--color-accent);
      color: var(--color-accent-on);
    }
    .filter-chip[aria-pressed="true"]:hover {
      background: var(--color-accent-dim);
      border-color: var(--color-accent-dim);
    }

    /* ── Collapsible filter sections ──────────────────── */
    .filter-section {
      border-bottom: 1px solid var(--color-border);
      padding: 10px 0;
    }
    .filter-section:first-of-type { padding-top: 0; }
    .filter-section:last-of-type { border-bottom: none; }
    .filter-section-toggle {
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 0.6rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-text-faint);
      cursor: pointer;
      list-style: none;
      user-select: none;
      padding: 2px 0;
      transition: color 0.12s;
    }
    .filter-section-toggle:hover { color: var(--color-text-muted); }
    .filter-section-toggle::-webkit-details-marker { display: none; }
    .filter-section-toggle::marker { display: none; content: ""; }
    .filter-chevron {
      display: inline-block;
      width: 0;
      height: 0;
      border-left: 3.5px solid transparent;
      border-right: 3.5px solid transparent;
      border-top: 3.5px solid currentColor;
      transition: transform 0.15s;
      flex-shrink: 0;
    }
    .filter-section:not([open]) .filter-chevron { transform: rotate(-90deg); }
    .filter-section-body {
      display: flex;
      flex-direction: column;
      gap: 10px;
      padding-top: 8px;
    }
    .filter-subgroup-label {
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 0.5rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-text-faint);
      opacity: 0.65;
      margin-bottom: 4px;
    }

    /* ── Mobile scroll rows ─────────────────────────────── */
    .filter-scroll-row {
      display: flex;
      align-items: center;
      gap: 6px;
      overflow-x: auto;
      padding-bottom: 2px;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }
    .filter-scroll-row::-webkit-scrollbar { display: none; }
    .filter-row-sep {
      flex-shrink: 0;
      width: 1px;
      height: 18px;
      background: var(--color-border);
      margin: 0 2px;
    }

    /* ── Reset button ───────────────────────────────────── */
    .reset-btn {
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 0.6rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-text-faint);
      text-decoration: underline;
      text-underline-offset: 3px;
      cursor: pointer;
      background: none;
      border: none;
      padding: 0;
      transition: color 0.12s;
    }
    .reset-btn:hover { color: var(--color-text-muted); }

    /* ── Price mode toggle ──────────────────────────────── */
    .price-toggle-group {
      display: flex;
      border: 1px solid var(--color-border);
      border-radius: 6px;
      overflow: hidden;
    }
    .price-toggle-btn {
      padding: 4px 12px;
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 0.65rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--color-text-muted);
      background: transparent;
      border: none;
      border-right: 1px solid var(--color-border);
      cursor: pointer;
      transition: background 0.1s, color 0.1s;
      white-space: nowrap;
    }
    .price-toggle-btn:last-child { border-right: none; }
    .price-toggle-btn:hover { background: var(--color-bg-subtle); color: var(--color-text); }
    .price-toggle-btn[data-active] {
      background: var(--color-accent);
      color: var(--color-accent-on);
    }

    /* ── Price display in cards ─────────────────────────── */
    .price-mode-aided { display: none; }
    body[data-price-mode="aided"] .price-mode-gross { display: none; }
    body[data-price-mode="aided"] .price-mode-aided { display: block; }
    body[data-price-mode="aided"] div.price-mode-aided { display: flex; flex-direction: column; gap: 1px; }

    /* ── Sort buttons ───────────────────────────────────── */
    .sort-btn {
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 0.7rem;
      letter-spacing: 0.05em;
      padding: 0.3rem 0.75rem;
      border-radius: 9999px;
      border: 1px solid var(--color-border);
      color: var(--color-text-muted);
      background: transparent;
      cursor: pointer;
      transition: border-color 0.15s, color 0.15s;
      white-space: nowrap;
    }
    .sort-btn:hover {
      border-color: var(--color-border-strong);
      color: var(--color-text);
    }
    .sort-btn[data-active] {
      border-color: var(--color-text);
      color: var(--color-text);
    }

    /* ── Range display in cards ─────────────────────────── */
    .range-mode-wltp { display: none; }
    body[data-range-mode="wltp"] .range-mode-real { display: none; }
    body[data-range-mode="wltp"] .range-mode-wltp { display: inline; }

    /* ── Range toggle group ─────────────────────────────── */
    .range-toggle-group {
      display: flex;
      background: var(--color-bg-subtle);
      border: 1px solid var(--color-border);
      border-radius: 6px;
      padding: 2px;
    }
    .range-toggle-btn {
      padding: 2px 8px;
      font-family: var(--font-sans);
      font-size: 10px;
      font-weight: 500;
      border-radius: 4px;
      border: none;
      background: transparent;
      color: var(--color-text-muted);
      cursor: pointer;
      transition: background-color 0.15s, color 0.15s, transform 0.1s;
      white-space: nowrap;
      -webkit-tap-highlight-color: transparent;
    }
    .range-toggle-btn:hover {
      color: var(--color-text);
    }
    .range-toggle-btn:active {
      transform: scale(0.95);
    }
    .range-toggle-btn[data-active="true"] {
      background: var(--color-accent);
      color: var(--color-accent-on);
    }
    @media (max-width: 1279px) {
      .range-toggle-btn {
        padding: 4px 10px;
      }
    }

    /* ── Custom Range Slider styling ─────────────────────── */
    input[type="range"] {
      -webkit-appearance: none;
      appearance: none;
      width: 100%;
      height: 4px;
      background: var(--color-border);
      border-radius: 9999px;
      outline: none;
      transition: background 0.15s;
    }
    input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none;
      appearance: none;
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: var(--color-accent);
      border: 2.5px solid var(--color-bg);
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.15), 0 0 0 1px var(--color-border-strong);
      cursor: pointer;
      transition: transform 0.1s var(--ease-spring), background-color 0.15s;
    }
    input[type="range"]::-moz-range-thumb {
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: var(--color-accent);
      border: 2.5px solid var(--color-bg);
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.15), 0 0 0 1px var(--color-border-strong);
      cursor: pointer;
      transition: transform 0.1s var(--ease-spring), background-color 0.15s;
    }
    input[type="range"]::-webkit-slider-thumb:hover {
      transform: scale(1.15);
      background: var(--color-accent-dim);
    }
    input[type="range"]::-moz-range-thumb:hover {
      transform: scale(1.15);
      background: var(--color-accent-dim);
    }
    input[type="range"]:active::-webkit-slider-thumb {
      transform: scale(0.95);
      background: var(--color-accent-dim);
    }
    input[type="range"]:active::-moz-range-thumb {
      transform: scale(0.95);
      background: var(--color-accent-dim);
    }

    /* ── Sidebar specific overrides (25% larger) ────────────────── */
    aside .filter-chip {
      gap: 6px;
      padding: 6px 12px;
      border-radius: 7px;
      font-size: 0.85rem;
    }
    aside .filter-section {
      padding: 12.5px 0;
    }
    aside .filter-section-toggle {
      font-size: 0.75rem;
      padding: 3px 0;
    }
    aside .filter-chevron {
      border-left: 4.5px solid transparent;
      border-right: 4.5px solid transparent;
      border-top: 4.5px solid currentColor;
    }
    aside .filter-subgroup-label {
      font-size: 0.625rem;
      margin-bottom: 5px;
