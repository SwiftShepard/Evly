---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BentoGrid from "@/components/ui/BentoGrid.astro";
import Tile from "@/components/ui/Tile.astro";
import Tag from "@/components/ui/Tag.astro";
import BrandLogo from "@/components/ui/BrandLogo.astro";
import VehicleImage from "@/components/ui/VehicleImage.astro";
import { getAllVehicles } from "@/lib/vehicles";
import { formatPrice } from "@/lib/format";
import { url } from "@/lib/url";
import FavoriteButton from "@/components/ui/FavoriteButton";
import type { Vehicle } from "@/data/schemas";

const vehicles = getAllVehicles();

// Véhicules considérés comme utilitaires / professionnels (flottes, navette VIP, ludospaces pro, vans Combi)
const UTILITY_SLUGS = new Set([
  "peugeot-e-rifter",
  "peugeot-e-traveller",
  "peugeot-e-expert-combi",
  "citroen-e-berlingo",
  "citroen-e-spacetourer",
  "renault-kangoo",
  "renault-grand-kangoo",
  "hyundai-staria",
  "kia-pv5-cargo",
]);

function getCategory(v: Vehicle) {
  // Utilitaire prend la priorité (avant Monospace pour récupérer e-Traveller, Staria, etc.)
  if (UTILITY_SLUGS.has(v.slug)) return "Utilitaire";

  const body = v.bodyType.toLowerCase();
  const segment = v.segment.toLowerCase();

  if (body.includes("monospace") || body.includes("van") || v.variant.toLowerCase().includes("monospace")) return "Monospace";
  if (body.includes("quadricycle") || v.segment.includes("quadricycle")) return "Quadricycle";
  if (segment.includes("a") || (segment.includes("b") && body.includes("suv")) || body.includes("urbain")) return "Mini-SUV";
  if (body.includes("suv") || body.includes("crossover")) return "SUV";
  if (segment.includes("b") || body.includes("citadine")) return "Citadine";
  if (segment.includes("c") || body.includes("compacte")) return "Compacte";
  if (body.includes("berline") || body.includes("hatchback") || segment.includes("d")) return "Berline";

  return "SUV";
}

function isLeasing(v: Vehicle) {
  const cheapestPrice = Math.min(...v.trims.map(t => t.price_EUR));
  const europeCountries = ["France", "Allemagne", "Slovaquie", "Rép. Tchèque", "Pologne", "Espagne", "Italie", "Belgique", "Suède", "Slovénie"];
  return cheapestPrice < 47000 && europeCountries.includes(v.productionCountry);
}

function isFamiliale(v: Vehicle) {
  const s = v.segment.toLowerCase();
  return s.includes("d") || s.includes("e") || v.bodyType.toLowerCase().includes("familial") || v.bodyType.toLowerCase().includes("monospace") || v.trunkCapacity_L > 450;
}

function isDaily(v: Vehicle) {
  const s = v.segment.toLowerCase();
  return s.includes("a") || s.includes("b") || s.includes("c");
}

const categories = ["Mini-SUV", "SUV", "Compacte", "Berline", "Citadine", "Monospace", "Utilitaire", "Quadricycle"];
const brands = [...new Set(vehicles.map((v) => v.brand))].sort((a, b) =>
  a.localeCompare(b, "fr", { sensitivity: "base" }),
);

const BRAND_ORIGINS: { label: string; set: Set<string> }[] = [
  { label: "Français", set: new Set(["Alpine", "Citroën", "Mobilize", "Peugeot", "Renault"]) },
  { label: "Allemand", set: new Set(["Audi", "BMW", "Mercedes", "Opel", "Smart", "Volkswagen"]) },
  { label: "Italien", set: new Set(["Alfa Romeo", "Fiat", "Lancia"]) },
  { label: "Coréen", set: new Set(["Hyundai", "Kia"]) },
  { label: "Japonais", set: new Set(["Mazda", "Nissan", "Toyota"]) },
  { label: "Américain", set: new Set(["Cadillac", "Ford", "Jeep", "Tesla"]) },
  { label: "Scandinave", set: new Set(["Polestar", "Volvo"]) },
  { label: "Chinois", set: new Set(["BYD", "Leapmotor", "Maxus", "MG", "Nio", "Xiaomi", "Xpeng", "Zeekr"]) },
];
const assignedBrands = new Set(BRAND_ORIGINS.flatMap((g) => [...g.set]));
const brandGroups = [
  ...BRAND_ORIGINS.map((g) => ({ label: g.label, items: brands.filter((b) => g.set.has(b)) })),
  { label: "Autres", items: brands.filter((b) => !assignedBrands.has(b)) },
].filter((g) => g.items.length > 0);

const budgetFilters = [
  { label: "< 25 k€", value: "25000" },
  { label: "< 35 k€", value: "35000" },
  { label: "< 50 k€", value: "50000" },
  { label: "< 70 k€", value: "70000" },
  { label: "< 100 k€", value: "100000" },
];
const specificFilters = [
  { label: "Favoris", value: "favorites" },
  { label: "Leasing social", value: "leasing" },
  { label: "Prime CEE", value: "bonus" },
  { label: "Recharge rapide", value: "fast-charge" },
  { label: "Made in Europe", value: "eu" },
  { label: "Familiale", value: "familiale" },
];

const europeanCountries = ["France", "Allemagne", "Slovaquie", "Rép. Tchèque", "Pologne", "Espagne", "Italie", "Belgique", "Suède", "Slovénie", "Hongrie", "Autriche", "Portugal"];
function isEU(v: Vehicle) { return europeanCountries.includes(v.productionCountry); }
function hasBonus(v: Vehicle) { return v.availableAids?.some(a => /prime\s*cee|bonus/i.test(a.label)) ?? false; }
---

<BaseLayout
  title="Véhicules, Evly"
  description="Liste exhaustive des véhicules électriques couverts par Evly. Filtrage multicritères par catégorie, marque et usage."
>
  <div class="py-6 md:py-10">
    <div class="container-edit">
      <div class="relative w-full flex flex-col">
        
        {/* Barre latérale (Filtres) débordant sur la gauche (Desktop) */}
        <aside class="hidden xl:block absolute top-0 right-full mr-8 w-[220px] h-full z-10">
          <div class="sticky top-24 flex flex-col gap-0 fade-rise">

            <details class="filter-section">
              <summary class="filter-section-toggle">Marques <span class="filter-chevron" /></summary>
              <div class="filter-section-body">
                {brandGroups.map((group) => (
                  <div>
                    <p class="filter-subgroup-label">{group.label}</p>
                    <div class="flex flex-wrap gap-1.5">
                      {group.items.map((b) => (
                        <button class="filter-chip" data-filter="brand" data-value={b} aria-pressed="false">
                          <BrandLogo brand={b} class="h-3 w-auto max-w-[32px] flex-shrink-0" />
                          <span>{b}</span>
                        </button>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </details>

            <details class="filter-section" open>
              <summary class="filter-section-toggle">Carrosserie <span class="filter-chevron" /></summary>
              <div class="filter-section-body">
                <div class="flex flex-wrap gap-1.5">
                  {categories.map((c) => (
                    <button class="filter-chip" data-filter="cat" data-value={c} aria-pressed="false">{c}</button>
                  ))}
                </div>
              </div>
            </details>

            <details class="filter-section" open>
              <summary class="filter-section-toggle">Budget max <span class="filter-chevron" /></summary>
              <div class="filter-section-body">
                <div class="flex flex-wrap gap-1.5">
                  {budgetFilters.map(({ label, value }) => (
                    <button class="filter-chip" data-filter="budget" data-value={value} aria-pressed="false">{label}</button>
                  ))}
                </div>
              </div>
            </details>

            <details class="filter-section" open>
              <summary class="filter-section-toggle">Spécifique <span class="filter-chevron" /></summary>
              <div class="filter-section-body">
                <div class="flex flex-wrap gap-1.5">
                  {specificFilters.map(({ label, value }) => (
                    <button class="filter-chip" data-filter="specific" data-value={value} aria-pressed="false">{label}</button>
                  ))}
                </div>
              </div>
            </details>

            <button id="reset-filters" class="reset-btn" style="display:none">Tout effacer</button>

          </div>
        </aside>

        {/* Filtres Mobile / Tablette, rangées défilantes */}
        <div class="xl:hidden w-full mb-6 flex flex-col gap-2 fade-rise">
          <div class="filter-scroll-row">
            {brandGroups.map((group, i) => (
              <>
                {i > 0 && <span class="filter-row-sep" />}
                {group.items.map((b) => (
                  <button class="filter-chip" data-filter="brand" data-value={b} aria-pressed="false">
                    <BrandLogo brand={b} class="h-3 w-auto max-w-[28px] flex-shrink-0" />
                    <span>{b}</span>
                  </button>
                ))}
              </>
            ))}
          </div>
          <div class="filter-scroll-row">
            {categories.map((c) => (
              <button class="filter-chip" data-filter="cat" data-value={c} aria-pressed="false">{c}</button>
            ))}
            <span class="filter-row-sep" />
            {budgetFilters.map(({ label, value }) => (
              <button class="filter-chip" data-filter="budget" data-value={value} aria-pressed="false">{label}</button>
            ))}
            <span class="filter-row-sep" />
            {specificFilters.map(({ label, value }) => (
              <button class="filter-chip" data-filter="specific" data-value={value} aria-pressed="false">{label}</button>
            ))}
          </div>
          <div class="flex">
            <button id="reset-filters-mobile" class="reset-btn" style="display:none">Tout effacer</button>
          </div>
        </div>

        {/* Contenu principal aligné avec container-edit */}
        <main class="w-full">
          <BentoGrid>
            <Tile size="full" variant="elevated">
              <div class="flex items-center gap-4 mb-6 fade-rise fade-rise-delay-1">
                <span class="font-mono text-xs text-[var(--color-text-faint)]">00</span>
                <span class="label-eyebrow">Catalogue</span>
              </div>
              <h1 class="display-1 max-w-3xl fade-rise fade-rise-delay-2">
                Tous les véhicules
                <span class="text-[var(--color-text-muted)]">· mis à jour {new Date().getFullYear()}.</span>
              </h1>
              <p class="mt-6 text-[var(--color-text-muted)] text-sm md:text-base max-w-2xl fade-rise fade-rise-delay-3">
                Sélectionnez vos critères de filtrage pour affiner la liste.
              </p>
              <div class="mt-8 pt-6 border-t border-[var(--color-border)] flex flex-wrap items-center gap-2 fade-rise fade-rise-delay-3">
                <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-text-faint)] mr-2">Trier</span>
                <button class="sort-btn" data-sort="default" data-active="true">Défaut</button>
                <button class="sort-btn" data-sort="price-asc">Prix ↑</button>
                <button class="sort-btn" data-sort="price-desc">Prix ↓</button>
                <button class="sort-btn" data-sort="range-desc">Autonomie réelle</button>
                <button class="sort-btn" data-sort="dc-desc">Recharge DC</button>
                <button class="sort-btn" data-sort="ratio-desc">Rapport km/€ ★</button>
                <span class="flex-1"></span>
                <div
                  id="price-mode-toggle"
                  class="price-toggle-group"
                  title="* Montants maximaux sous conditions de revenus, d'eligibilite et de mise au rebut. Prime CEE maj. mai 2026."
                >
                  <button class="price-toggle-btn" data-mode="gross" data-active="true">Brut</button>
                  <button class="price-toggle-btn" data-mode="aided">Après aides max.*</button>
                </div>
              </div>
            </Tile>

        {vehicles.map((v) => {
          const cheapest = v.trims.reduce((a, b) => (a.price_EUR < b.price_EUR ? a : b));
          const totalAids = v.availableAids.reduce((s, a) => s + a.amount_EUR, 0);
          const priceAided = Math.max(0, cheapest.price_EUR - totalAids);
          const category = getCategory(v);
          
          const familial = isFamiliale(v) ? "Familiale" : "";
          const daily = isDaily(v) ? "Daily" : "";
          const leasing = isLeasing(v) ? "Leasing social" : "";
          const usageTags = [familial, daily, leasing].filter(Boolean).join(",");

          return (
            <div
              data-slug={v.slug}
              data-category={category}
              data-brand={v.brand}
              data-usage={usageTags}
              data-price={cheapest.price_EUR}
              data-price-aided={priceAided}
              data-range={v.realRange.mixed_km}
              data-dc={v.chargingDC.peakPower_kW}
              data-ratio={Math.round(v.realRange.mixed_km / cheapest.price_EUR * 10000)}
              data-origin={isEU(v) ? "eu" : "other"}
              data-bonus={hasBonus(v) ? "1" : "0"}
              class="vehicle-card contents"
            >
              <Tile size="2x1" variant="default" href={url(`/vehicules/${v.slug}`)} ariaLabel={`Fiche ${v.brand} ${v.model} ${v.variant}`} class="reveal">
                <div class="flex items-center justify-between gap-3 mb-4">
                  <div class="flex items-center gap-2 text-[var(--color-text-muted)]">
                    <BrandLogo brand={v.brand} class="w-4 h-4" />
                    <span class="label-eyebrow">{v.brand} · {v.segment.split(", ")[0] ?? v.segment}</span>
                  </div>
                  <div class="flex items-center gap-2 flex-wrap justify-end">
                    {isLeasing(v) && <Tag tone="accent" mono>Leasing social</Tag>}
                    <Tag tone="outline" mono>{v.architecture_V} V</Tag>
                    <FavoriteButton client:load slug={v.slug} size={15} />
                  </div>
                </div>
                <div class="flex items-end gap-3 mb-6">
                  <h2 class="font-display text-2xl md:text-3xl font-semibold tracking-[-0.015em] leading-[1.05]">
                    {v.model}
                    <span class="block text-[var(--color-text-muted)] text-lg md:text-xl mt-1 font-medium">{v.variant}</span>
                  </h2>
                  <div class="flex-1 flex justify-center items-end">
                    <VehicleImage
                      slug={v.slug}
                      alt={`${v.brand} ${v.model}`}
                      class="w-28 h-14"
                    />
                  </div>
                </div>
                <div class="grid grid-cols-3 gap-4 mt-auto pt-5 border-t border-[var(--color-border)]">
                  <div class="flex flex-col gap-1">
                    <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-text-faint)]">Auto.</span>
                    <div class="flex items-baseline gap-1">
                      <span data-numeric class="display-stat text-2xl md:text-3xl text-[var(--color-accent)]">{v.realRange.mixed_km}</span>
                      <span class="font-mono text-[11px] text-[var(--color-text-faint)]">km</span>
                    </div>
                  </div>
                  <div class="flex flex-col gap-1">
                    <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-text-faint)]">DC</span>
                    <div class="flex items-baseline gap-1">
                      <span data-numeric class="display-stat text-2xl md:text-3xl">{v.chargingDC.peakPower_kW}</span>
                      <span class="font-mono text-[11px] text-[var(--color-text-faint)]">kW</span>
                    </div>
                  </div>
                  <div class="flex flex-col gap-1">
                    <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-text-faint)]">
                      <span class="price-mode-gross">Dès</span>
                      <span class="price-mode-aided">Après aides max.*</span>
                    </span>
                    <div class="price-mode-gross">
                      <span data-numeric class="display-stat text-2xl md:text-3xl">{formatPrice(cheapest.price_EUR)}</span>
                    </div>
                    <div class="price-mode-aided">
                      <span data-numeric class="display-stat text-2xl md:text-3xl" style="color:var(--color-accent)">{formatPrice(priceAided)}</span>
                      {totalAids > 0 && <span class="font-mono text-[10px] text-[var(--color-text-faint)]" style="text-decoration:line-through">{formatPrice(cheapest.price_EUR)}</span>}
                    </div>
                  </div>
                </div>
              </Tile>
            </div>
          );
        })}
      </BentoGrid>
    </main>
  </div>

  <script is:inline>
    const chips    = document.querySelectorAll('.filter-chip');
    const cards    = document.querySelectorAll('.vehicle-card');
    const sortBtns = document.querySelectorAll('.sort-btn');
    const grid     = document.querySelector('.bento-grid');
    const resetBtns = document.querySelectorAll('#reset-filters, #reset-filters-mobile');
    const originalOrder = Array.from(cards);

    // Price mode, 'gross' | 'aided'
    let priceMode = 'gross';
    let currentSort = 'default';

    function getCardPrice(card) {
      if (priceMode === 'aided') return +(card.dataset.priceAided ?? card.dataset.price);
      return +card.dataset.price;
    }

    // Shared active state across desktop + mobile chip duplicates
    const active = { brand: new Set(), cat: new Set(), budget: new Set(), specific: new Set() };

    function getSelected(type) { return Array.from(active[type]); }

    function syncChips(filter, value) {
      document.querySelectorAll(`.filter-chip[data-filter="${filter}"][data-value="${value}"]`)
        .forEach(c => c.setAttribute('aria-pressed', active[filter].has(value) ? 'true' : 'false'));
    }

    function updateResetVisibility() {
      const any = Object.values(active).some(s => s.size > 0);
      resetBtns.forEach(b => b.style.display = any ? '' : 'none');
    }

    function getFavorites() {
      try {
        const raw = localStorage.getItem('evly-favorites');
        return raw ? JSON.parse(raw) : [];
      } catch { return []; }
    }

    window.addEventListener('favorites-changed', () => updateFilters());

    function updateFilters() {
      const selBrands   = getSelected('brand');
      const selCats     = getSelected('cat');
      const selBudgets  = getSelected('budget');
      const selSpecific = getSelected('specific');
      const favSlugs    = selSpecific.includes('favorites') ? new Set(getFavorites()) : null;

      cards.forEach(card => {
        const brand   = card.dataset.brand;
        const cat     = card.dataset.category;
        const price   = getCardPrice(card);
        const dc      = +card.dataset.dc;
        const origin  = card.dataset.origin;
        const bonus   = card.dataset.bonus === '1';
        const usages  = (card.dataset.usage || '').split(',').filter(Boolean);
        const slug    = card.dataset.slug;

        let ok = true;
        if (selBrands.length  && !selBrands.includes(brand)) ok = false;
        if (selCats.length    && !selCats.includes(cat))     ok = false;
        if (selBudgets.length) {
          const maxBudget = Math.max(...selBudgets.map(Number));
          if (price > maxBudget) ok = false;
        }
        if (selSpecific.length) {
          for (const s of selSpecific) {
            if (s === 'favorites'   && (!favSlugs || !favSlugs.has(slug)))  { ok = false; break; }
            if (s === 'fast-charge' && dc < 100)                     { ok = false; break; }
            if (s === 'eu'          && origin !== 'eu')               { ok = false; break; }
            if (s === 'bonus'       && !bonus)                        { ok = false; break; }
            if (s === 'leasing'     && !usages.includes('Leasing social')) { ok = false; break; }
            if (s === 'familiale'   && !usages.includes('Familiale'))      { ok = false; break; }
          }
        }
        card.style.display = ok ? 'contents' : 'none';
      });
    }

    chips.forEach(chip => {
      chip.addEventListener('click', () => {
        const f = chip.dataset.filter;
        const v = chip.dataset.value;
        if (active[f].has(v)) active[f].delete(v);
        else                   active[f].add(v);
        syncChips(f, v);
        updateFilters();
        updateResetVisibility();
      });
    });

    resetBtns.forEach(btn => btn.addEventListener('click', () => {
      Object.values(active).forEach(s => s.clear());
      chips.forEach(c => c.setAttribute('aria-pressed', 'false'));
      updateFilters();
      updateResetVisibility();
    }));

    function applySort(sortKey) {
      currentSort = sortKey;
      sortBtns.forEach(btn => delete btn.dataset.active);
      document.querySelector(`.sort-btn[data-sort="${sortKey}"]`).dataset.active = 'true';
      const sorted = sortKey === 'default'
        ? [...originalOrder]
        : [...originalOrder].sort((a, b) => {
            switch (sortKey) {
              case 'price-asc':  return getCardPrice(a) - getCardPrice(b);
              case 'price-desc': return getCardPrice(b) - getCardPrice(a);
              case 'range-desc': return +b.dataset.range - +a.dataset.range;
              case 'dc-desc':    return +b.dataset.dc    - +a.dataset.dc;
              case 'ratio-desc': return +b.dataset.ratio - +a.dataset.ratio;
              default:           return 0;
            }
          });
      sorted.forEach(card => grid.appendChild(card));
    }

    sortBtns.forEach(btn => btn.addEventListener('click', () => applySort(btn.dataset.sort)));

    // Price mode toggle
    const priceBtns = document.querySelectorAll('.price-toggle-btn');
    priceBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        priceMode = btn.dataset.mode;
        priceBtns.forEach(b => delete b.dataset.active);
        btn.dataset.active = 'true';
        document.body.dataset.priceMode = priceMode;
        updateFilters();
        applySort(currentSort);
      });
    });
  </script>

  <style>
    /* ── Filter chips ───────────────────────────────────── */
    .filter-chip {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 5px 10px;
      border-radius: 6px;
      border: 1px solid var(--color-border);
      background: transparent;
      color: var(--color-text-muted);
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 0.68rem;
      letter-spacing: 0.025em;
      cursor: pointer;
      transition: background 0.12s, border-color 0.12s, color 0.12s, transform 0.08s;
      white-space: nowrap;
      -webkit-tap-highlight-color: transparent;
      user-select: none;
      line-height: 1.2;
    }
    .filter-chip:hover {
      background: var(--color-bg-subtle);
      border-color: var(--color-border-strong);
      color: var(--color-text);
    }
    .filter-chip:active { transform: scale(0.96); }
    .filter-chip[aria-pressed="true"] {
      background: var(--color-accent);
      border-color: var(--color-accent);
      color: var(--color-accent-on);
    }
    .filter-chip[aria-pressed="true"]:hover {
      background: var(--color-accent-dim);
      border-color: var(--color-accent-dim);
    }

    /* ── Collapsible filter sections ──────────────────── */
    .filter-section {
      border-bottom: 1px solid var(--color-border);
      padding: 10px 0;
    }
    .filter-section:first-of-type { padding-top: 0; }
    .filter-section:last-of-type { border-bottom: none; }
    .filter-section-toggle {
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 0.6rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-text-faint);
      cursor: pointer;
      list-style: none;
      user-select: none;
      padding: 2px 0;
      transition: color 0.12s;
    }
    .filter-section-toggle:hover { color: var(--color-text-muted); }
    .filter-section-toggle::-webkit-details-marker { display: none; }
    .filter-section-toggle::marker { display: none; content: ""; }
    .filter-chevron {
      display: inline-block;
      width: 0;
      height: 0;
      border-left: 3.5px solid transparent;
      border-right: 3.5px solid transparent;
      border-top: 3.5px solid currentColor;
      transition: transform 0.15s;
      flex-shrink: 0;
    }
    .filter-section:not([open]) .filter-chevron { transform: rotate(-90deg); }
    .filter-section-body {
      display: flex;
      flex-direction: column;
      gap: 10px;
      padding-top: 8px;
    }
    .filter-subgroup-label {
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 0.5rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-text-faint);
      opacity: 0.65;
      margin-bottom: 4px;
    }

    /* ── Mobile scroll rows ─────────────────────────────── */
    .filter-scroll-row {
      display: flex;
      align-items: center;
      gap: 6px;
      overflow-x: auto;
      padding-bottom: 2px;
      scrollbar-width: none;
      -webkit-overflow-scrolling: touch;
    }
    .filter-scroll-row::-webkit-scrollbar { display: none; }
    .filter-row-sep {
      flex-shrink: 0;
      width: 1px;
      height: 18px;
      background: var(--color-border);
      margin: 0 2px;
    }

    /* ── Reset button ───────────────────────────────────── */
    .reset-btn {
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 0.6rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-text-faint);
      text-decoration: underline;
      text-underline-offset: 3px;
      cursor: pointer;
      background: none;
      border: none;
      padding: 0;
      transition: color 0.12s;
    }
    .reset-btn:hover { color: var(--color-text-muted); }

    /* ── Price mode toggle ──────────────────────────────── */
    .price-toggle-group {
      display: flex;
      border: 1px solid var(--color-border);
      border-radius: 6px;
      overflow: hidden;
    }
    .price-toggle-btn {
      padding: 4px 12px;
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 0.65rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--color-text-muted);
      background: transparent;
      border: none;
      border-right: 1px solid var(--color-border);
      cursor: pointer;
      transition: background 0.1s, color 0.1s;
      white-space: nowrap;
    }
    .price-toggle-btn:last-child { border-right: none; }
    .price-toggle-btn:hover { background: var(--color-bg-subtle); color: var(--color-text); }
    .price-toggle-btn[data-active] {
      background: var(--color-accent);
      color: var(--color-accent-on);
    }

    /* ── Price display in cards ─────────────────────────── */
    .price-mode-aided { display: none; }
    body[data-price-mode="aided"] .price-mode-gross { display: none; }
    body[data-price-mode="aided"] .price-mode-aided { display: block; }
    body[data-price-mode="aided"] div.price-mode-aided { display: flex; flex-direction: column; gap: 1px; }

    /* ── Sort buttons ───────────────────────────────────── */
    .sort-btn {
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 0.7rem;
      letter-spacing: 0.05em;
      padding: 0.3rem 0.75rem;
      border-radius: 9999px;
      border: 1px solid var(--color-border);
      color: var(--color-text-muted);
      background: transparent;
      cursor: pointer;
      transition: border-color 0.15s, color 0.15s;
      white-space: nowrap;
    }
    .sort-btn:hover {
      border-color: var(--color-border-strong);
      color: var(--color-text);
    }
    .sort-btn[data-active] {
      border-color: var(--color-text);
      color: var(--color-text);
    }
  </style>
</BaseLayout>
