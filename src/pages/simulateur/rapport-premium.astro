---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PremiumReportDashboard from "@/components/premium/PremiumReportDashboard";
import { getAllVehicles } from "@/lib/vehicles";

const vehicles = getAllVehicles().map((v) => {
  const cheapest = v.trims.reduce((a, b) =>
    a.price_EUR < b.price_EUR ? a : b
  );
  const aids = v.availableAids.reduce((sum, a) => sum + a.amount_EUR, 0);
  return {
    slug: v.slug,
    brand: v.brand,
    model: v.model,
    variant: v.variant,
    segment: v.segment,
    price_EUR: cheapest.price_EUR,
    aids_EUR: aids,
    consumption_kWh_100km: v.consumption_mixed_kWh_per_100km,
    realRange_mixed_km: v.realRange.mixed_km,
    configs: v.configurations.map((c) => ({
      id: c.id,
      label: c.label,
      trim: c.trim,
      battery: c.battery,
      price_EUR: c.price_EUR,
      consumption_kWh_100km: c.wltp_consumption_kWh_100km,
      realRange_mixed_km: c.realRange?.mixed_km ?? v.realRange.mixed_km,
    })),
  };
});
---

<BaseLayout title="Rapport Premium B2C | Evly" description="Votre rapport PDF Premium personnalisé indépendant.">
  <PremiumReportDashboard client:only="react" vehicles={vehicles} />
</BaseLayout>

<style>
  /* ── Print Media layout (4 exact A4 pages) ───────────── */
  @media print {
    .no-print {
      display: none !important;
    }
    body, html {
      background: #ffffff !important;
      color: #111111 !important;
      font-size: 11pt !important;
    }
    .premium-report-container {
      width: 100% !important;
      max-width: 100% !important;
      padding: 0 !important;
      margin: 0 !important;
    }
    :global(.report-page) {
      display: flex !important;
      flex-direction: column !important;
      justify-content: space-between !important;
      height: 297mm !important; /* Height of A4 */
      width: 210mm !important;  /* Width of A4 */
      page-break-after: always !important;
      break-after: page !important;
      padding: 1.5cm !important;
      box-sizing: border-box !important;
      background: #ffffff !important;
      border: none !important;
      box-shadow: none !important;
    }
    :global(table), :global(tr), :global(td), :global(th) {
      page-break-inside: avoid !important;
    }
  }

  /* ── Screen layout (Premium Interactive Dashboard) ───── */
  :global(.premium-report-container) {
    font-family: var(--font-sans);
  }
  :global(.report-page) {
    background: var(--color-surface);
    border: 0.5px solid var(--color-border);
    border-radius: 20px;
    padding: 2.5rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
    min-height: 600px;
  }
  :global(.report-logo) {
    font-family: var(--font-display);
  }
</style>
