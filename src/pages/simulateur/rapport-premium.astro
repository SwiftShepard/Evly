---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PremiumReportDashboard from "@/components/premium/PremiumReportDashboard";
import { getAllVehicles } from "@/lib/vehicles";

const vehicles = getAllVehicles();
---

<BaseLayout title="Rapport Premium B2C | Evly" description="Votre rapport PDF Premium personnalisé indépendant.">
  <PremiumReportDashboard client:only="react" vehicles={vehicles} />
</BaseLayout>

<style is:global>
  /* ── Print Media layout (4 exact A4 pages) ───────────── */
  @media print {
    .no-print, header, footer, nav, #reading-progress, .reading-progress, [class*="nav-header"] {
      display: none !important;
    }
    body, html {
      background: #ffffff !important;
      color: #111111 !important;
      font-size: 10pt !important;
      margin: 0 !important;
      padding: 0 !important;
    }
    .premium-report-container {
      width: 100% !important;
      max-width: 100% !important;
      padding: 0 !important;
      margin: 0 !important;
    }
    :global(.report-page) {
      display: flex !important;
      flex-direction: column !important;
      justify-content: space-between !important;
      height: 296mm !important; /* Slightly under 297mm to prevent blank pages */
      width: 210mm !important;  /* Width of A4 */
      page-break-after: always !important;
      break-after: page !important;
      padding: 1.8cm !important;
      box-sizing: border-box !important;
      background: #ffffff !important;
      border: none !important;
      box-shadow: none !important;
    }
    :global(table), :global(tr), :global(td), :global(th) {
      page-break-inside: avoid !important;
    }
  }

  /* ── Screen layout (Premium Interactive Dashboard) ───── */
  :global(.premium-report-container) {
    font-family: var(--font-sans);
  }
  :global(.report-page) {
    background: var(--color-surface);
    border: 0.5px solid var(--color-border);
    border-radius: 20px;
    padding: 2.5rem;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
    min-height: 600px;
  }
  :global(.report-logo) {
    font-family: var(--font-display);
  }
</style>
