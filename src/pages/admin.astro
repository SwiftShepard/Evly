---
/**
 * /admin — Tableau de bord contenu Evly
 *
 * Cette page est réservée à l'usage local (dev).
 * Elle n'est pas liée dans le nav et un guard client-side
 * redirige vers "/" si le hostname n'est pas localhost / 127.0.0.1.
 */
import { getAllVehicles } from "@/lib/vehicles";
import AdminPanel, { type VehicleAdminRow } from "@/components/admin/AdminPanel";

const vehicles = getAllVehicles();

/* ---------------------------------------------------------------- */
/* Détection assets disponibles (build-time)                        */
/* ---------------------------------------------------------------- */

const imageGlob = import.meta.glob("/src/assets/vehicles/*");
const logoGlob  = import.meta.glob("/src/assets/logos/*");

// Extraire les slugs de fichiers images → "renault-5" etc.
const imageSlugs = new Set(
  Object.keys(imageGlob).map((p) => {
    const m = p.match(/\/src\/assets\/vehicles\/(.+)\.\w+$/);
    return m?.[1] ?? "";
  })
);

// Extraire les slugs de logos → "renault", "kia", etc.
const logoSlugs = new Set(
  Object.keys(logoGlob).map((p) => {
    const m = p.match(/\/src\/assets\/logos\/(.+)\.\w+$/);
    return m?.[1] ?? "";
  })
);

/* ---------------------------------------------------------------- */
/* Construire les lignes pour le panel                              */
/* ---------------------------------------------------------------- */

function parseBatteryKwh(batteryUsed: string): number | null {
  const m = batteryUsed.match(/(\d+(?:[.,]\d+)?)/);
  return m ? Math.round(parseFloat(m[1].replace(",", "."))) : null;
}

const adminRows: VehicleAdminRow[] = vehicles.map((v) => {
  const brandSlug = v.brand
    .toLowerCase()
    .replace(/ë/g, "e")
    .replace(/é/g, "e")
    .replace(/\s+/g, "-");

  const batteries = [...new Set(v.configurations.map((c) => c.battery))];
  const hasBothBatteries = batteries.includes("standard") && batteries.includes("long-range");

  // Label par batterie : "std 40kWh" / "lr 77kWh"
  const lrKwh = Math.round(v.usableCapacity_kWh);
  const stdKwh = (() => {
    const stdTrims = v.trims.filter((t) => {
      const k = parseBatteryKwh(t.batteryUsed);
      return k !== null && k < lrKwh;
    });
    if (stdTrims.length === 0) return null;
    return parseBatteryKwh(stdTrims[0]!.batteryUsed);
  })();

  const batteryLabels: string[] = batteries.map((b) => {
    if (b === "long-range") return `lr ${lrKwh}kWh`;
    return stdKwh ? `std ${stdKwh}kWh` : "std";
  });

  // Si une seule batterie unique (vehicles sans long-range distinct)
  if (batteries.length === 1 && batteries[0] === "standard" && !stdKwh) {
    batteryLabels[0] = `std ${lrKwh}kWh`;
  }

  const hasRangeTests =
    v.rangeTests.length > 0 || v.configurations.some((c) => c.rangeTests.length > 0);

  const cheapestPrice =
    v.trims.length > 0 ? Math.min(...v.trims.map((t) => t.price_EUR)) : 0;

  return {
    slug: v.slug,
    brand: v.brand,
    model: v.model,
    variant: v.variant,
    segment: v.segment,
    hasImage: imageSlugs.has(v.slug),
    hasLogo: logoSlugs.has(brandSlug),
    configsCount: v.configurations.length,
    trimsCount: v.trims.length,
    batteryLabels,
    hasBothBatteries,
    wltp_min: v.wltp_min_km,
    wltp_max: v.wltp_max_km,
    realRangeMixed: v.realRange.mixed_km,
    realRangeHighway: v.realRange.highway_130_km,
    realRangeConfidence: v.realRange.confidence,
    hasRangeTests,
    sourcesCount: v.sources.length,
    sources: v.sources,
    cheapestPrice,
    lastUpdated: v.lastUpdated,
    releaseYear: v.releaseYear,
  };
});
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Admin · Evly</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { height: 100%; background: #0a0a0a; color: #e5e5e5; font-family: monospace; }
      ::-webkit-scrollbar { width: 6px; height: 6px; }
      ::-webkit-scrollbar-track { background: #111; }
      ::-webkit-scrollbar-thumb { background: #333; border-radius: 3px; }
      ::-webkit-scrollbar-thumb:hover { background: #555; }
      input[type="search"]::-webkit-search-cancel-button { display: none; }
      input { outline: none; }
      a { color: inherit; }
    </style>
  </head>
  <body>
    <!-- Guard client-side : redirige si hors localhost -->
    <script>
      (function () {
        const h = window.location.hostname;
        if (h !== "localhost" && h !== "127.0.0.1" && !h.startsWith("192.168.")) {
          window.location.replace("/");
        }
      })();
    </script>

    <AdminPanel client:load vehicles={adminRows} />
  </body>
</html>
