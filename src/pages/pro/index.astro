---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BentoGrid from "@/components/ui/BentoGrid.astro";
import Tile from "@/components/ui/Tile.astro";
import Tag from "@/components/ui/Tag.astro";
import BrandLogo from "@/components/ui/BrandLogo.astro";
import VehicleImage from "@/components/ui/VehicleImage.astro";
import { getAllVehicles } from "@/lib/vehicles";
import { formatPrice } from "@/lib/format";
import { url } from "@/lib/url";

const vehicles = getAllVehicles();

// Mêmes slugs que UTILITY_SLUGS dans /vehicules/index.astro
const UTILITY_SLUGS = new Set([
  // Utilitaires de base
  "peugeot-e-rifter",
  "peugeot-e-traveller",
  "peugeot-e-expert-combi",
  "citroen-e-berlingo",
  "citroen-e-spacetourer",
  "renault-kangoo",
  "renault-grand-kangoo",
  "hyundai-staria",
  "kia-pv5-cargo",
  "kia-pv5-passenger",
  // Vague utilitaires V2 (A2)
  "renault-master-e-tech",
  "renault-trafic-e-tech",
  "peugeot-e-partner",
  "peugeot-e-boxer",
  "citroen-e-jumpy",
  "citroen-e-jumper",
  "opel-combo-e-life",
  "opel-vivaro-e-life",
  "opel-movano-e",
  "fiat-e-ducato",
  "fiat-e-scudo",
  "toyota-proace-electric",
  "toyota-proace-max-electric",
  "toyota-proace-city",
  "mercedes-eqv",
  "ford-e-transit",
  "maxus-edeliver-3",
  "maxus-edeliver-5",
  "maxus-edeliver-7",
  "maxus-edeliver-9",
]);

const utilities = vehicles
  .filter((v) => UTILITY_SLUGS.has(v.slug))
  .sort((a, b) => Math.min(...a.trims.map((t) => t.price_EUR)) - Math.min(...b.trims.map((t) => t.price_EUR)));

const description =
  "💼 Électrifiez votre flotte d'entreprise au meilleur coût ! Simulateur TCO réel, cumul d'aides fiscales 2026 (CEE, suramortissement) et audit indépendant.";
---

<BaseLayout title="Evly Pro : Électrification de Flotte Auto & Calculateur TCO" description={description}>
  <div class="container-edit py-6 md:py-10">
    <BentoGrid>
      {/* ═══════ HERO ═══════ */}
      <Tile size="full" variant="elevated" class="md:!p-12 lg:!p-16">
        <div class="flex items-center justify-end mb-10 md:mb-14 fade-rise">
          <Tag tone="accent" mono>Beta</Tag>
        </div>

        <h1 class="display-1 max-w-4xl fade-rise fade-rise-delay-1">
          L'électrique pour vos flottes,
          <span class="text-[var(--color-accent)]">sans pari.</span>
        </h1>

        <p class="mt-6 md:mt-8 font-display text-xl md:text-2xl lg:text-3xl font-medium tracking-[-0.01em] leading-[1.2] text-[var(--color-text-muted)] max-w-3xl fade-rise fade-rise-delay-2">
          TCO réel, aides 2026 cumulées, sélection utilitaires audités.
        </p>

        <p class="mt-8 md:mt-10 text-sm md:text-base text-[var(--color-text-muted)] max-w-2xl leading-relaxed fade-rise fade-rise-delay-3">
          Évly Pro applique la même méthodologie indépendante que le site grand public à la décision d'électrification des flottes professionnelles. Aucun lien constructeur, aucune commission de leasing.
        </p>

        <div class="mt-10 md:mt-12 flex flex-wrap items-center gap-3 fade-rise fade-rise-delay-3">
          <a href="#tco" class="btn-interactive btn-glow inline-flex items-center gap-2 px-5 py-3 bg-[var(--color-accent)] text-[var(--color-accent-on)] text-sm font-medium tracking-tight min-h-[44px] hover:bg-[var(--color-accent-dim)] transition-colors rounded-[var(--radius-tile-sm)]">
            Calculer mon TCO ↓
          </a>
          <a href="mailto:pro@evly.fr?subject=Demande%20d%27audit%20flotte" class="btn-interactive inline-flex items-center gap-2 px-5 py-3 border border-[var(--color-border-strong)] text-[var(--color-text)] text-sm font-medium tracking-tight min-h-[44px] hover:bg-[var(--color-bg-subtle)] transition-colors rounded-[var(--radius-tile-sm)]">
            Demander un audit
          </a>
        </div>
      </Tile>

      {/* ═══════ 01 · POURQUOI MAINTENANT ═══════ */}
      <Tile size="full" variant="default" label="01 · Contexte">
        <h2 class="font-display text-3xl md:text-4xl font-semibold tracking-[-0.015em] leading-[1.1] mb-6">
          Pourquoi accélérer maintenant.
        </h2>
        <div class="grid md:grid-cols-3 gap-6 md:gap-8">
          <div class="flex flex-col gap-2">
            <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-accent)]">A · Fiscal</span>
            <h3 class="font-display text-lg font-semibold tracking-[-0.01em]">Empilement d'aides 2026</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
              Coup de pouce CEE, suramortissement 40-60 %, exoneration TVS, TVA 100 % recuperable sur l'electricite, credit d'impot bornes, cumulables.
            </p>
          </div>
          <div class="flex flex-col gap-2">
            <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-accent)]">B · Réglementaire</span>
            <h3 class="font-display text-lg font-semibold tracking-[-0.01em]">ZFE et obligation LOM</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
              Loi LOM impose un % de véhicules à faibles émissions dans le renouvellement des flottes > 100 véhicules. Les ZFE excluent progressivement les thermiques.
            </p>
          </div>
          <div class="flex flex-col gap-2">
            <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-accent)]">C · Économique</span>
            <h3 class="font-display text-lg font-semibold tracking-[-0.01em]">TCO franchement favorable</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
              Sur 5 ans / 30 000 km/an, le coût total d'un VE utilitaire est généralement inférieur de 20-35 % à son équivalent diesel, calculez ci-dessous votre cas.
            </p>
          </div>
        </div>
      </Tile>

      {/* ═══════ 02 · CALCULATEUR TCO ═══════ */}
      <Tile size="full" variant="elevated" label="02 · Calculateur TCO" class="!mt-2">
        <div id="tco" class="scroll-mt-24"></div>
        <h2 class="font-display text-3xl md:text-4xl font-semibold tracking-[-0.015em] leading-[1.1] mb-3">
          Calculateur TCO, ICE vs EV.
        </h2>
        <p class="text-sm md:text-base text-[var(--color-text-muted)] max-w-3xl mb-8">
          Comparaison sur la durée de détention. Méthodologie simple : prix d'achat (− aides) + consommation × prix énergie × km. Hors entretien, assurance, valeur résiduelle.
        </p>

        <div class="grid md:grid-cols-2 gap-8 md:gap-10">
          {/* INPUTS */}
          <div class="flex flex-col gap-4">
            <span class="label-eyebrow">Vos hypothèses</span>

            <div class="grid grid-cols-2 gap-3">
              <label class="tco-field">
                <span>Km/an</span>
                <input id="tco-km" type="number" value="25000" min="1000" step="1000" />
              </label>
              <label class="tco-field">
                <span>Durée (ans)</span>
                <input id="tco-years" type="number" value="5" min="1" max="15" step="1" />
              </label>
            </div>

            <div class="tco-block">
              <span class="tco-block-label">Véhicule électrique</span>
              <div class="grid grid-cols-2 gap-3 mt-2">
                <label class="tco-field">
                  <span>Prix neuf (€)</span>
                  <input id="tco-ev-price" type="number" value="42000" min="0" step="500" />
                </label>
                <label class="tco-field">
                  <span>Aides cumulées (€)</span>
                  <input id="tco-ev-aids" type="number" value="5500" min="0" step="100" />
                </label>
                <label class="tco-field">
                  <span>Conso (kWh/100 km)</span>
                  <input id="tco-ev-conso" type="number" value="20" min="5" max="40" step="0.5" />
                </label>
                <label class="tco-field">
                  <span>Prix élec (€/kWh)</span>
                  <input id="tco-ev-energy" type="number" value="0.20" min="0.05" max="0.60" step="0.01" />
                </label>
              </div>
            </div>

            <div class="tco-block">
              <span class="tco-block-label">Équivalent diesel / essence</span>
              <div class="grid grid-cols-2 gap-3 mt-2">
                <label class="tco-field">
                  <span>Prix neuf (€)</span>
                  <input id="tco-ice-price" type="number" value="36000" min="0" step="500" />
                </label>
                <label class="tco-field">
                  <span>Aides (€)</span>
                  <input id="tco-ice-aids" type="number" value="0" min="0" step="100" />
                </label>
                <label class="tco-field">
                  <span>Conso (L/100 km)</span>
                  <input id="tco-ice-conso" type="number" value="7.0" min="2" max="20" step="0.1" />
                </label>
                <label class="tco-field">
                  <span>Prix carburant (€/L)</span>
                  <input id="tco-ice-energy" type="number" value="1.75" min="0.5" max="3" step="0.01" />
                </label>
              </div>
            </div>
          </div>

          {/* RESULTS */}
          <div class="flex flex-col gap-4">
            <span class="label-eyebrow">Résultat sur la période</span>

            <div class="tco-result-block tco-result-ev">
              <span class="tco-result-label">Coût total VE</span>
              <p data-numeric id="tco-out-ev-total" class="display-stat text-3xl md:text-4xl text-[var(--color-accent)]">0 €</p>
              <p class="text-xs text-[var(--color-text-muted)] mt-2">
                Achat net <span id="tco-out-ev-net">0</span> € + énergie <span id="tco-out-ev-energy">0</span> €
              </p>
            </div>

            <div class="tco-result-block tco-result-ice">
              <span class="tco-result-label">Coût total ICE</span>
              <p data-numeric id="tco-out-ice-total" class="display-stat text-3xl md:text-4xl text-[var(--color-text-muted)]">0 €</p>
              <p class="text-xs text-[var(--color-text-muted)] mt-2">
                Achat net <span id="tco-out-ice-net">0</span> € + carburant <span id="tco-out-ice-energy">0</span> €
              </p>
            </div>

            <div id="tco-savings-block" class="tco-result-block tco-result-savings">
              <span class="tco-result-label">Écart EV vs ICE</span>
              <p data-numeric id="tco-out-savings" class="display-stat text-3xl md:text-4xl">0 €</p>
              <p id="tco-out-savings-detail" class="text-xs text-[var(--color-text-muted)] mt-2">
                Soit <span id="tco-out-savings-pct">0</span> sur la période · point d'équilibre à <span id="tco-out-breakeven">0</span> an(s)
              </p>
            </div>

            <p class="text-[11px] font-mono text-[var(--color-text-faint)] leading-relaxed">
              Calcul indicatif hors maintenance, assurance, valeur résiduelle, TVS. Les VE bénéficient en plus d'une exonération TVS, d'une TVA 100 % récupérable sur l'électricité et du suramortissement pour les utilitaires &gt; 2,6 t, gains supplémentaires non modélisés ici.
            </p>
          </div>
        </div>
      </Tile>

      {/* ═══════ 03 · AIDES 2026 ═══════ */}
      <Tile size="full" variant="default" label="03 · Aides 2026 cumulables" class="!mt-2">
        <h2 class="font-display text-3xl md:text-4xl font-semibold tracking-[-0.015em] leading-[1.1] mb-3">
          Le mille-feuille fiscal 2026.
        </h2>
        <p class="text-sm md:text-base text-[var(--color-text-muted)] max-w-3xl mb-8">
          Ces dispositifs sont cumulables sous conditions. Un audit personnalisé permet d'optimiser le mix selon le segment (VUL, PL, VP de fonction) et la structure (TPE, ETI, grand compte).
        </p>

        <div class="aid-table">
          <div class="aid-row aid-row-header">
            <div>Aide</div>
            <div>Mécanisme · Montant</div>
            <div>Pour qui</div>
          </div>

          <div class="aid-row">
            <div class="aid-name"><strong>Coup de pouce CEE Pro</strong></div>
            <div>Variable selon operateur CEE · bareme pro distinct du particulier</div>
            <div>VE &lt; 47 k€ · &lt; 2,4 t · score ADEME &ge; 60/80 · personnes morales</div>
          </div>

          <div class="aid-row">
            <div class="aid-name"><strong>Suramortissement</strong></div>
            <div>Déduction fiscale supplémentaire 40 à 60 % du surcoût électrique</div>
            <div>VUL &gt; 2,6 t et PL, selon PTAC (60 % pour 2,6-3,5 t, 40 % pour 3,5-16 t, 20 % au-delà)</div>
          </div>

          <div class="aid-row">
            <div class="aid-name"><strong>Exonération TVS</strong></div>
            <div>100 % d'exonération de la Taxe sur les Véhicules de Société</div>
            <div>Tous les véhicules électriques de société</div>
          </div>

          <div class="aid-row">
            <div class="aid-name"><strong>TVA récupérable élec</strong></div>
            <div>100 % de la TVA récupérable sur l'électricité de recharge (vs 80 % sur carburant)</div>
            <div>Toutes les entreprises assujetties</div>
          </div>

          <div class="aid-row">
            <div class="aid-name"><strong>Crédit d'impôt bornes</strong></div>
            <div>75 % du coût d'installation · plafonné 300 €/borne (site domicile salarié) ou règle entreprise</div>
            <div>Installation de bornes au domicile salarié ou sur site entreprise</div>
          </div>

          <div class="aid-row">
            <div class="aid-name"><strong>Aides régionales</strong></div>
            <div>Variables · ex. Île-de-France jusqu'à 9 000 €/véhicule pro VUL, AURA, BFC</div>
            <div>Selon implantation siège / établissement</div>
          </div>

          <div class="aid-row">
            <div class="aid-name"><strong>ZFE</strong></div>
            <div>Exemption complète de restriction de circulation (Crit'Air E)</div>
            <div>Toutes flottes opérant en zone ZFE (Paris, Lyon, Grenoble, Marseille…)</div>
          </div>

          <div class="aid-row">
            <div class="aid-name"><strong>Forfait Mobilités Durables</strong></div>
            <div>Jusqu'à 800 €/an exonérés de charges sociales et IR</div>
            <div>Versé par l'employeur au salarié, incite recharge perso</div>
          </div>

          <div class="aid-row">
            <div class="aid-name"><strong>Appels à projets ADEME</strong></div>
            <div>Subventions ciblées flottes ≥ 10 véhicules · stations de recharge collectives</div>
            <div>Grandes flottes, collectivités, intercommunalités</div>
          </div>
        </div>
      </Tile>

      {/* ═══════ 04 · SÉLECTION UTILITAIRES ═══════ */}
      <Tile size="full" variant="default" label="04 · Notre sélection actuelle" class="!mt-2">
        <div class="flex flex-wrap items-end justify-between gap-4 mb-2">
          <h2 class="font-display text-3xl md:text-4xl font-semibold tracking-[-0.015em] leading-[1.05]">
            {utilities.length} utilitaires audités.
            <span class="block text-[var(--color-text-muted)] text-lg md:text-xl mt-2 font-medium">
              Ludospaces et navettes professionnelles couverts par Évly.
            </span>
          </h2>
          <a href={url("/pro/vehicules")} class="font-mono text-[11px] uppercase tracking-[0.12em] text-[var(--color-text-muted)] hover:text-[var(--color-text)]">Showroom Pro →</a>
        </div>
        <p class="text-sm text-[var(--color-text-muted)] mt-4 max-w-3xl">
          Découvrez la gamme complète de nos véhicules utilitaires électriques audités pour votre entreprise : Master / Trafic E-Tech, Peugeot e-Partner / e-Expert / e-Boxer, Stellantis vans (ë-Jumpy, ë-Jumper, ë-Berlingo Van), Mercedes eSprinter / eVito, Ford E-Transit et Maxus eDeliver.
        </p>
      </Tile>

      {utilities.map((v) => {
        const cheapest = v.trims.reduce((a, b) => (a.price_EUR < b.price_EUR ? a : b));
        return (
          <Tile size="2x1" variant="default" href={url(`/vehicules/${v.slug}`)} ariaLabel={`Fiche ${v.brand} ${v.model}`} class="reveal">
            <div class="flex items-center justify-between gap-3 mb-4">
              <div class="flex items-center gap-2 text-[var(--color-text-muted)]">
                <BrandLogo brand={v.brand} class="w-4 h-4" />
                <span class="label-eyebrow">{v.brand}</span>
              </div>
              <Tag tone="outline" mono>Pro · {v.bodyType}</Tag>
            </div>
            <div class="flex items-end gap-3 mb-6">
              <h3 class="font-display text-2xl md:text-3xl font-semibold tracking-[-0.015em] leading-[1.05]">
                {v.model}
                <span class="block text-[var(--color-text-muted)] text-base md:text-lg mt-1 font-medium">{v.variant}</span>
              </h3>
              <div class="flex-1 flex justify-center items-end">
                <VehicleImage slug={v.slug} alt={`${v.brand} ${v.model}`} class="w-28 h-14" />
              </div>
            </div>
            <div class="grid grid-cols-3 gap-4 mt-auto pt-5 border-t border-[var(--color-border)]">
              <div class="flex flex-col gap-1">
                <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-text-faint)]">Auto.</span>
                <div class="flex items-baseline gap-1">
                  <span data-numeric class="display-stat text-2xl md:text-3xl text-[var(--color-accent)]">{v.realRange.mixed_km}</span>
                  <span class="font-mono text-[11px] text-[var(--color-text-faint)]">km</span>
                </div>
              </div>
              <div class="flex flex-col gap-1">
                <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-text-faint)]">Coffre</span>
                <div class="flex items-baseline gap-1">
                  <span data-numeric class="display-stat text-2xl md:text-3xl">{v.trunkCapacity_L}</span>
                  <span class="font-mono text-[11px] text-[var(--color-text-faint)]">L</span>
                </div>
              </div>
              <div class="flex flex-col gap-1">
                <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-text-faint)]">Dès</span>
                <span data-numeric class="display-stat text-2xl md:text-3xl">{formatPrice(cheapest.price_EUR)}</span>
              </div>
            </div>
          </Tile>
        );
      })}

      {/* ═══════ 05 · SAAS TEASER ═══════ */}
      <Tile size="full" variant="elevated" label="05 · Evly Pro Dashboard" class="!mt-4">
        <div class="flex items-center gap-3 mb-4">
          <Tag tone="accent" mono>En construction</Tag>
          <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-text-faint)]">V2 · 2026</span>
        </div>
        <h2 class="display-2 max-w-3xl mb-6">
          Bientôt : un dashboard flotte.
        </h2>
        <p class="text-[var(--color-text-muted)] text-base md:text-lg max-w-3xl leading-relaxed mb-8">
          Évly Pro arrive en SaaS. Au-delà du calculateur ci-dessus, un espace dédié pour piloter votre transition électrique de A à Z, avec une seule promesse : <strong class="text-[var(--color-text)]">aucune commission constructeur ou loueur</strong>.
        </p>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8 pt-6 border-t border-[var(--color-border)]">
          <div class="flex flex-col gap-2">
            <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-accent)]">01</span>
            <h3 class="font-display text-base font-semibold">Cartographie flotte</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
              Import CSV de votre parc actuel, classement par segment, identification des candidats à l'électrification.
            </p>
          </div>
          <div class="flex flex-col gap-2">
            <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-accent)]">02</span>
            <h3 class="font-display text-base font-semibold">ROI véhicule par véhicule</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
              TCO 5 ans détaillé par véhicule remplacé, avec breakdown énergie / fiscal / suramortissement / valeur résiduelle.
            </p>
          </div>
          <div class="flex flex-col gap-2">
            <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-accent)]">03</span>
            <h3 class="font-display text-base font-semibold">Audit aides automatisé</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
              Optimisation du mix CEE + suramortissement + aides régionales selon votre profil. Export PDF pour expert-comptable.
            </p>
          </div>
          <div class="flex flex-col gap-2">
            <span class="font-mono text-[10px] uppercase tracking-[0.14em] text-[var(--color-accent)]">04</span>
            <h3 class="font-display text-base font-semibold">Recommandation multi-fournisseurs</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
              Comparaison constructeurs sans biais commercial. Données mises à jour mensuellement.
            </p>
          </div>
        </div>

        <div class="mt-10 pt-6 border-t border-[var(--color-border)] flex flex-col md:flex-row gap-4">
          <a href="mailto:pro@evly.fr?subject=Acc%C3%A8s%20anticip%C3%A9%20Evly%20Pro&body=Bonjour%2C%20je%20suis%20int%C3%A9ress%C3%A9%28e%29%20par%20Evly%20Pro%20pour%20notre%20flotte%20de%20%5Bnombre%5D%20v%C3%A9hicules." class="btn-interactive btn-glow inline-flex items-center justify-center gap-2 px-5 py-3 bg-[var(--color-accent)] text-[var(--color-accent-on)] text-sm font-medium tracking-tight min-h-[44px] hover:bg-[var(--color-accent-dim)] transition-colors rounded-[var(--radius-tile-sm)]">
            Demander l'accès anticipé →
          </a>
          <a href="mailto:pro@evly.fr?subject=Demande%20d%27audit%20flotte" class="btn-interactive inline-flex items-center justify-center gap-2 px-5 py-3 border border-[var(--color-border-strong)] text-[var(--color-text)] text-sm font-medium tracking-tight min-h-[44px] hover:bg-[var(--color-bg-subtle)] transition-colors rounded-[var(--radius-tile-sm)]">
            Audit personnalisé (gratuit)
          </a>
        </div>
        <p class="mt-6 text-[11px] font-mono text-[var(--color-text-faint)]">
          Évly Pro est gratuit en phase beta. Modèle SaaS payant à terme (abonnement par véhicule au parc). Aucun engagement, sortie à tout moment.
        </p>
      </Tile>
    </BentoGrid>
  </div>

  <style>
    /* ── Calculateur TCO ───────────────────────────────────── */
    .tco-field {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .tco-field span {
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-text-faint);
    }
    .tco-field input {
      padding: 8px 10px;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-tile-sm);
      background: var(--color-bg);
      color: var(--color-text);
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 14px;
      transition: border-color 0.15s;
    }
    .tco-field input:focus {
      outline: none;
      border-color: var(--color-accent);
    }
    .tco-block {
      padding: 14px;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-tile-sm);
      background: var(--color-bg-subtle);
    }
    .tco-block-label {
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 10px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--color-text);
    }

    .tco-result-block {
      padding: 16px 18px;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-tile-sm);
      background: var(--color-bg-subtle);
    }
    .tco-result-label {
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 10px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--color-text-faint);
      display: block;
      margin-bottom: 6px;
    }
    .tco-result-ev {
      border-left: 2px solid var(--color-accent);
    }
    .tco-result-savings {
      background: color-mix(in srgb, var(--color-accent) 6%, transparent);
      border-color: var(--color-accent-dim);
    }
    .tco-result-savings.negative {
      background: color-mix(in srgb, var(--color-warning) 6%, transparent);
      border-color: color-mix(in srgb, var(--color-warning) 45%, var(--color-border-strong));
    }
    .tco-result-savings #tco-out-savings { color: var(--color-accent); }
    .tco-result-savings.negative #tco-out-savings { color: var(--color-warning); }

    /* ── Tableau aides ─────────────────────────────────────── */
    .aid-table {
      display: flex;
      flex-direction: column;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-tile-sm);
      overflow: hidden;
    }
    .aid-row {
      display: grid;
      grid-template-columns: 1.2fr 2fr 1.8fr;
      gap: 16px;
      padding: 14px 18px;
      border-top: 1px solid var(--color-border);
      font-size: 14px;
      line-height: 1.5;
    }
    .aid-row:first-child { border-top: none; }
    .aid-row-header {
      background: var(--color-bg-subtle);
      font-family: var(--font-mono, ui-monospace, monospace);
      font-size: 11px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-text-muted);
    }
    .aid-name { color: var(--color-text); }
    .aid-row > div:nth-child(2),
    .aid-row > div:nth-child(3) {
      color: var(--color-text-muted);
    }
    @media (max-width: 768px) {
      .aid-row {
        grid-template-columns: 1fr;
        gap: 6px;
      }
      .aid-row-header { display: none; }
      .aid-name { font-size: 15px; }
    }
  </style>

  <script is:inline>
    // Calculateur TCO, JS vanilla, recalcul à chaque input
    (() => {
      const $ = (id) => document.getElementById(id);
      const fmt = (n) => new Intl.NumberFormat("fr-FR", { maximumFractionDigits: 0 }).format(Math.round(n));
      const inputs = [
        "tco-km", "tco-years",
        "tco-ev-price", "tco-ev-aids", "tco-ev-conso", "tco-ev-energy",
        "tco-ice-price", "tco-ice-aids", "tco-ice-conso", "tco-ice-energy",
      ];

      function calc() {
        const km = +$("tco-km").value || 0;
        const years = +$("tco-years").value || 1;
        const evPrice = +$("tco-ev-price").value || 0;
        const evAids = +$("tco-ev-aids").value || 0;
        const evConso = +$("tco-ev-conso").value || 0;
        const evEnergy = +$("tco-ev-energy").value || 0;
        const icePrice = +$("tco-ice-price").value || 0;
        const iceAids = +$("tco-ice-aids").value || 0;
        const iceConso = +$("tco-ice-conso").value || 0;
        const iceEnergy = +$("tco-ice-energy").value || 0;

        const evNet = Math.max(0, evPrice - evAids);
        const iceNet = Math.max(0, icePrice - iceAids);
        const evEnergyCost = (km * years * evConso / 100) * evEnergy;
        const iceEnergyCost = (km * years * iceConso / 100) * iceEnergy;
        const evTotal = evNet + evEnergyCost;
        const iceTotal = iceNet + iceEnergyCost;
        const savings = iceTotal - evTotal;
        const savingsPct = iceTotal > 0 ? (savings / iceTotal) * 100 : 0;
        // Breakeven : (evNet - iceNet) / (iceEnergyAnnual - evEnergyAnnual)
        const evEnergyAnnual = (km * evConso / 100) * evEnergy;
        const iceEnergyAnnual = (km * iceConso / 100) * iceEnergy;
        const overPrice = evNet - iceNet;
        const energySavingsAnnual = iceEnergyAnnual - evEnergyAnnual;
        let breakeven = null;
        if (energySavingsAnnual > 0 && overPrice > 0) {
          breakeven = overPrice / energySavingsAnnual;
        } else if (overPrice <= 0) {
          breakeven = 0;
        }

        $("tco-out-ev-net").textContent = fmt(evNet);
        $("tco-out-ev-energy").textContent = fmt(evEnergyCost);
        $("tco-out-ev-total").textContent = fmt(evTotal) + " €";
        $("tco-out-ice-net").textContent = fmt(iceNet);
        $("tco-out-ice-energy").textContent = fmt(iceEnergyCost);
        $("tco-out-ice-total").textContent = fmt(iceTotal) + " €";

        const savingsEl = $("tco-out-savings");
        const savingsBlock = $("tco-savings-block");
        const sign = savings >= 0 ? "− " : "+ ";
        savingsEl.textContent = sign + fmt(Math.abs(savings)) + " €";
        savingsBlock.classList.toggle("negative", savings < 0);

        $("tco-out-savings-pct").textContent = (savings >= 0 ? "−" : "+") + fmt(Math.abs(savingsPct)) + " %";
        if (breakeven === null) {
          $("tco-out-breakeven").textContent = "n/c";
        } else if (breakeven === 0) {
          $("tco-out-breakeven").textContent = "immédiat";
        } else {
          $("tco-out-breakeven").textContent = breakeven.toFixed(1);
        }
      }

      inputs.forEach((id) => {
        const el = $(id);
        if (el) el.addEventListener("input", calc);
      });
      calc();
    })();
  </script>
</BaseLayout>
